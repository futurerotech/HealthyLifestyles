---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Analytics from '../components/Analytics.astro';
import WebVitals from '../components/WebVitals.astro';
import AdSlot from '../components/AdSlot.astro';
import AdsLoader from '../components/AdsLoader.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
  /** Full-bleed pages (e.g. hero) set their own top spacing. */
  mainClass?: string;
  /** Disable header ad slot on this page. */
  noHeaderAd?: boolean;
  /** P15-P6: BCP-47 language for <html lang>. Defaults to 'en'. */
  lang?: string;
  /** P15-P6: reciprocal hreflang alternates (self + x-default). Empty = no hreflang. */
  alternates?: { hreflang: string; href: string }[];
  /** P15-P6: og:locale override for localized pages. */
  ogLocale?: string;
}

const {
  title,
  description,
  image,
  type,
  noindex,
  jsonLd,
  mainClass,
  noHeaderAd,
  lang = 'en',
  alternates = [],
  ogLocale,
} = Astro.props;

// P15-P6: RTL for Arabic (and any future RTL locale) — drives layout mirroring.
const dir = lang === 'ar' || lang.startsWith('ar-') ? 'rtl' : 'ltr';
---

<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <!-- Enable scroll-reveal before first paint (so [data-reveal] starts hidden);
         skipped entirely for reduced-motion users. -->
    <script is:inline>
      try {
        if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('js-reveal');
        }
      } catch (e) {}
    </script>
    <!-- Per-page head injection (preloads, etc.) -->
    <slot name="head" />

    <!-- Preload the two variable fonts used above the fold (LCP/CLS) -->
    <link rel="preload" href="/fonts/plus-jakarta-sans-variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <!-- Speculation Rules: prerender same-origin pages on hover/pointerdown
         (moderate eagerness) for near-instant navigation, with a conservative
         prefetch fallback. Excludes API routes, framable /embed pages, OG image
         endpoints, and any link tagged [data-no-prerender]. Progressive
         enhancement — browsers without support ignore it. GA4 + the lazy ad
         loader are activation/interaction-driven, so prerender won't double-fire. -->
    <script type="speculationrules" is:inline set:html={JSON.stringify({
      prerender: [{
        where: { and: [
          { href_matches: '/*' },
          { not: { href_matches: '/api/*' } },
          { not: { href_matches: '/embed/*' } },
          { not: { href_matches: '/og/*' } },
          { not: { selector_matches: '[data-no-prerender]' } },
          { not: { selector_matches: '[rel~="nofollow"]' } },
        ] },
        eagerness: 'moderate',
      }],
      prefetch: [{
        where: { and: [
          { href_matches: '/*' },
          { not: { href_matches: '/api/*' } },
        ] },
        eagerness: 'conservative',
      }],
    })} />
    {/* AdSense loads ONCE, consent-gated, from <AdsLoader> (rendered in body).
        No ad scripts are hardcoded in <head>. */}
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
      alternates={alternates}
      ogLocale={ogLocale}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    {!noHeaderAd && <AdSlot placement="header" format="leaderboard" />}
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <Analytics />
    <WebVitals />
    <AdsLoader />

    <!-- Global AdSense initializer — the ONE and ONLY place adsbygoogle.push()
         is called. AdSlot renders bare <ins> tags; this initializes each one
         LAZILY via IntersectionObserver, so a slot is pushed only once it is
         actually visible and laid out. This fixes two failure modes at once:
           1) Speculation-Rules prerender — IO callbacks don't run in a hidden
              prerender, so the push is naturally deferred to activation (no
              blank-on-activation).
           2) "availableWidth=0" TagError — before pushing we wait two paint
              frames and verify the <ins> has a non-zero width, so a collapsed
              or display:none slot (e.g. the mobile-hidden sidebar) is never
              pushed.
         Idempotent: :not([data-adsbygoogle-status]) skips filled units and a
         one-shot data-ad-observed marker prevents double-observing if init runs
         again (astro:page-load is included only to future-proof View Transitions). -->
    <script is:inline>
      function pushAd(el) {
        // Two rAFs guarantee layout has been computed before AdSense measures width.
        requestAnimationFrame(function () {
          requestAnimationFrame(function () {
            if (el.getBoundingClientRect().width === 0) {
              console.warn('[AdSense] slot still 0px wide after paint — skipped', el);
              return;
            }
            try {
              (window.adsbygoogle = window.adsbygoogle || []).push({});
            } catch (e) {
              console.error('[AdSense] push() failed:', e);
            }
          });
        });
      }
      function initUninitializedAds() {
        var slots = document.querySelectorAll(
          '.adsbygoogle:not([data-adsbygoogle-status]):not([data-ad-observed])'
        );
        if (!slots.length) return;
        var io = new IntersectionObserver(function (entries, obs) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              obs.unobserve(entry.target);
              pushAd(entry.target);
            }
          });
        }, { rootMargin: '200px 0px', threshold: 0.01 });
        slots.forEach(function (s) {
          s.setAttribute('data-ad-observed', '');
          io.observe(s);
        });
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initUninitializedAds);
      } else {
        initUninitializedAds();
      }
      document.addEventListener('astro:page-load', initUninitializedAds);
    </script>

    <script>
      // Reveal [data-reveal] sections once as they scroll into view. Failsafe:
      // anything still hidden after 2.4s is revealed, so content can never get
      // stuck (background tabs, 0x0 viewports, observer quirks).
      const els = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
      const reveal = (el: HTMLElement) => el.classList.add('is-revealed');
      if (!els.length) {
        /* nothing to do */
      } else if (!document.documentElement.classList.contains('js-reveal') || !('IntersectionObserver' in window)) {
        els.forEach(reveal);
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                reveal(e.target as HTMLElement);
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.04 },
        );
        els.forEach((el) => io.observe(el));
        window.setTimeout(() => els.forEach(reveal), 2400);
      }
    </script>
  </body>
</html>
