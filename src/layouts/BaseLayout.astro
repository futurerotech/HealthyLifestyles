---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import Analytics from '../components/Analytics.astro';
import AdSlot from '../components/AdSlot.astro';
import AdsLoader from '../components/AdsLoader.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
  /** Full-bleed pages (e.g. hero) set their own top spacing. */
  mainClass?: string;
  /** Disable header ad slot on this page. */
  noHeaderAd?: boolean;
}

const {
  title,
  description,
  image,
  type,
  noindex,
  jsonLd,
  mainClass,
  noHeaderAd,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <!-- Enable scroll-reveal before first paint (so [data-reveal] starts hidden);
         skipped entirely for reduced-motion users. -->
    <script is:inline>
      try {
        if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('js-reveal');
        }
      } catch (e) {}
    </script>
    <!-- Preload the two variable fonts used above the fold (LCP/CLS) -->
    <link rel="preload" href="/fonts/plus-jakarta-sans-variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/fonts/inter-variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <!-- Speculation Rules: prerender same-origin pages on hover/pointerdown
         (moderate eagerness) for near-instant navigation, with a conservative
         prefetch fallback. Excludes API routes, framable /embed pages, OG image
         endpoints, and any link tagged [data-no-prerender]. Progressive
         enhancement — browsers without support ignore it. GA4 + the lazy ad
         loader are activation/interaction-driven, so prerender won't double-fire. -->
    <script type="speculationrules" is:inline set:html={JSON.stringify({
      prerender: [{
        where: { and: [
          { href_matches: '/*' },
          { not: { href_matches: '/api/*' } },
          { not: { href_matches: '/embed/*' } },
          { not: { href_matches: '/og/*' } },
          { not: { selector_matches: '[data-no-prerender]' } },
          { not: { selector_matches: '[rel~="nofollow"]' } },
        ] },
        eagerness: 'moderate',
      }],
      prefetch: [{
        where: { and: [
          { href_matches: '/*' },
          { not: { href_matches: '/api/*' } },
        ] },
        eagerness: 'conservative',
      }],
    })} />
    {/* AdSense loads ONCE, consent-gated, from <AdsLoader> (rendered in body).
        No ad scripts are hardcoded in <head>. */}
    <SEO
      title={title}
      description={description}
      image={image}
      type={type}
      noindex={noindex}
      jsonLd={jsonLd}
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    {!noHeaderAd && <AdSlot placement="header" format="leaderboard" />}
    <main id="main" class={mainClass}>
      <slot />
    </main>
    <Footer />
    <CookieConsent />
    <Analytics />
    <AdSlot placement="stickyFooter" format="mobileBanner" />
    <AdsLoader />

    <!-- Global AdSense initializer — the ONE and ONLY place adsbygoogle.push()
         is called. AdSlot renders bare <ins> tags; this pushes each one that
         isn't initialized yet. It is deliberately prerender-aware: a push inside
         a Speculation-Rules prerender (hidden page) leaves the slot permanently
         blank, so we skip while document.prerendering is true and (re)run on
         activation. The :not([data-adsbygoogle-status]) guard makes every
         re-run idempotent (no "already have ads" errors). astro:page-load is
         included so it keeps working if View Transitions is ever added. -->
    <script is:inline>
      function initUninitializedAds() {
        if (document.prerendering) return; // never fill ads in a hidden prerender
        document.querySelectorAll('.adsbygoogle:not([data-adsbygoogle-status])').forEach(function () {
          try {
            (window.adsbygoogle = window.adsbygoogle || []).push({});
          } catch (e) {
            console.error('[AdSense] push() failed:', e);
          }
        });
      }
      // Direct (non-prerendered) load fires now; guarded no-op while prerendering.
      initUninitializedAds();
      // Activation of a prerendered page — the real fix for this site.
      document.addEventListener('prerenderingchange', initUninitializedAds);
      // First load + back/forward cache restores.
      document.addEventListener('DOMContentLoaded', initUninitializedAds);
      window.addEventListener('pageshow', initUninitializedAds);
      // Future-proof: fires only if <ClientRouter/> (View Transitions) is added.
      document.addEventListener('astro:page-load', initUninitializedAds);
    </script>

    <script>
      // Reveal [data-reveal] sections once as they scroll into view. Failsafe:
      // anything still hidden after 2.4s is revealed, so content can never get
      // stuck (background tabs, 0x0 viewports, observer quirks).
      const els = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));
      const reveal = (el: HTMLElement) => el.classList.add('is-revealed');
      if (!els.length) {
        /* nothing to do */
      } else if (!document.documentElement.classList.contains('js-reveal') || !('IntersectionObserver' in window)) {
        els.forEach(reveal);
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                reveal(e.target as HTMLElement);
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.04 },
        );
        els.forEach((el) => io.observe(el));
        window.setTimeout(() => els.forEach(reveal), 2400);
      }
    </script>
  </body>
</html>
