---
/**
 * Shared shell for legal / policy pages (privacy, terms, disclaimer, cookies).
 * Renders a compact header, breadcrumb, last-updated note, and a prose slot.
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  description: string;
  /** Short H1 shown in the page header (defaults to `title`). */
  heading?: string;
  /** Human-readable last revision date, e.g. "June 1, 2026". */
  updated?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, heading, updated, noindex, jsonLd } = Astro.props;

const items = [
  { label: 'Home', href: '/' },
  { label: heading ?? title },
];
---

<BaseLayout title={title} description={description} noindex={noindex} jsonLd={jsonLd}>
  <header class="legal__header section-mint">
    <div class="container container-narrow">
      <Breadcrumb items={items} />
      <h1 class="legal__title">{heading ?? title}</h1>
      {updated && <p class="legal__updated">Last updated: {updated}</p>}
    </div>
  </header>

  <section class="section">
    <div class="container container-narrow">
      <div class="legal-prose">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .legal__header {
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
  }
  .legal__title {
    margin: 1rem 0 0.4rem;
    font-size: clamp(1.9rem, 4vw, 2.6rem);
  }
  .legal__updated {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--muted);
  }

  .legal-prose :global(h2) {
    font-size: 1.4rem;
    margin: 2.25rem 0 0.85rem;
    scroll-margin-top: calc(var(--header-h) + 1rem);
  }
  .legal-prose :global(h2:first-child) {
    margin-top: 0;
  }
  .legal-prose :global(h3) {
    font-size: 1.1rem;
    margin: 1.5rem 0 0.5rem;
  }
  .legal-prose :global(p),
  .legal-prose :global(li) {
    color: #334155;
    line-height: 1.7;
  }
  .legal-prose :global(p) {
    margin-bottom: 1rem;
  }
  .legal-prose :global(ul),
  .legal-prose :global(ol) {
    margin: 0 0 1rem 1.25rem;
    display: grid;
    gap: 0.5rem;
  }
  .legal-prose :global(a) {
    color: var(--green-700);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .legal-prose :global(strong) {
    color: var(--ink);
  }
  .legal-prose :global(.legal-note) {
    background: var(--mint-50);
    border: 1px solid #d1fae5;
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }
  .legal-prose :global(.legal-note p:last-child) {
    margin-bottom: 0;
  }
</style>
