---
// Lazy AdSense loader — loads adsbygoogle.js ONLY on first user interaction
// (scroll, mousemove, touchstart, click, keydown) after consent.
// This component only gates the library load for PageSpeed.
// Partytown: loads the script in a web worker (off main thread).
// Non-Partytown: dynamically injects a script tag on interaction.
import { ADS } from '../consts';
import { getAdConfig } from '../lib/ad-config';

const enabled = !!ADS.client && /^ca-pub-\d+$/.test(ADS.client);
const adConfig = await getAdConfig();
const usePartytown = adConfig?.partytownEnabled !== false;
const clientId = adConfig?.adsenseClient || ADS.client;
---

{
  enabled && (
    <>
      <!-- Partytown snippet (loaded in web worker if enabled) -->
      {usePartytown && (
        <script type="text/partytown" data-pt-src={"https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=" + clientId}
          async crossOrigin="anonymous">
        </script>
      )}

      <!-- Consent + Interaction-detection (main thread) -->
      <script is:inline data-pt-skip define:vars={{ clientId, usePt: usePartytown }}>
        (function () {
          var loaded = false;

          function loadScript() {
            if (loaded) return;
            loaded = true;
            if (!usePt) {
              var s = document.createElement('script');
              s.async = true;
              s.crossOrigin = 'anonymous';
              s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + clientId;
              document.head.appendChild(s);
            }
          }

          var interactionEvents = ['scroll', 'mousemove', 'touchstart', 'click', 'keydown'];
          function onInteraction() {
            interactionEvents.forEach(function (ev) {
              document.removeEventListener(ev, onInteraction);
            });
            loadScript();
          }
          interactionEvents.forEach(function (ev) {
            document.addEventListener(ev, onInteraction, { passive: true, once: true });
          });

          document.addEventListener('consent-update', function (e) {
            if (e && e.detail && e.detail.analytics) {
              interactionEvents.forEach(function (ev) {
                document.removeEventListener(ev, onInteraction);
              });
              loadScript();
            }
          });
        })();
      </script>

      <!-- Sticky footer close button handler -->
      <script is:inline data-pt-skip>
        document.addEventListener('click', function (e) {
          var btn = e.target?.closest && e.target.closest('[data-close-sticky]');
          if (btn) {
            var sticky = btn.closest('.ad--sticky');
            if (sticky) sticky.classList.add('ad--sticky-hidden');
          }
        });
      </script>
    </>
  )
}
