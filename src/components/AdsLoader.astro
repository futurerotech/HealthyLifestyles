---
/**
 * The ONE and ONLY AdSense loader for the whole site.
 *
 * Loads adsbygoogle.js (our ca-pub client) exactly once, on the main thread,
 * and ONLY after cookie consent (window.HLS_CONSENT === 'accept' or the
 * `consent-update` event with analytics granted). Every ad UNIT comes from the
 * <AdSlot> component, driven by the Ad Management global — no ad code lives
 * anywhere else. Also wires the sticky-footer ad's close button.
 */
import { ADS } from '../consts';
import { getAdConfig } from '../lib/ad-config';

const adConfig = await getAdConfig();
const clientId = adConfig?.adsenseClient || ADS.client;
const enabled = !!clientId && /^ca-pub-\d+$/.test(clientId);
---

{
  enabled && (
    <script is:inline data-pt-skip define:vars={{ clientId }}>
      (function () {
        var loaded = false;
        function loadAdSense() {
          if (loaded) return;
          loaded = true;
          var s = document.createElement('script');
          s.async = true;
          s.crossOrigin = 'anonymous';
          s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=' + clientId;
          document.head.appendChild(s);
        }
        // Gated behind cookie consent — never loads before the user accepts.
        if (window.HLS_CONSENT === 'accept') loadAdSense();
        document.addEventListener('consent-update', function (e) {
          if (e && e.detail && e.detail.analytics) loadAdSense();
        });
      })();
    </script>
  )
}

<!-- Sticky footer ad close button -->
<script is:inline data-pt-skip>
  document.addEventListener('click', function (e) {
    var btn = e.target && e.target.closest && e.target.closest('[data-close-sticky]');
    if (btn) {
      var sticky = btn.closest('.ad--sticky');
      if (sticky) sticky.classList.add('ad--sticky-hidden');
    }
  });
</script>
