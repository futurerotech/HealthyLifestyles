---
/**
 * Ad UX helper. The AdSense library itself is loaded on the MAIN THREAD from
 * <head> (see BaseLayout — Partytown can't serve AdSense reliably). This file
 * only wires the sticky-footer ad's close button.
 */
---

<script is:inline data-pt-skip>
  document.addEventListener('click', function (e) {
    var btn = e.target && e.target.closest && e.target.closest('[data-close-sticky]');
    if (btn) {
      var sticky = btn.closest('.ad--sticky');
      if (sticky) sticky.classList.add('ad--sticky-hidden');
    }
  });
</script>
