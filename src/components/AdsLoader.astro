---
/**
 * The ONE and ONLY AdSense loader for the whole site.
 *
 * Loads adsbygoogle.js (our ca-pub client) exactly once for all visitors, using
 * the standard async Google integration so it never blocks the main thread or
 * degrades PageSpeed. No consent gate (US-first audience). Every ad UNIT comes
 * from the <AdSlot> component, driven by the Ad Management global — no ad code
 * lives anywhere else. Also wires the sticky-footer ad's close button.
 */
import { ADS } from '../consts';
import { getAdConfig } from '../lib/ad-config';

const adConfig = await getAdConfig();
const clientId = adConfig?.adsenseClient || ADS.client;
// Master toggle: when the CMS is reachable, "Adsense Enabled = false" stops the
// library from loading at all. consts only apply when the CMS is unreachable.
const masterOn = adConfig ? adConfig.adsenseEnabled !== false : true;
const enabled = masterOn && !!clientId && /^ca-pub-\d+$/.test(clientId);
---

{
  enabled && (
    <script
      async
      src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${clientId}`}
      crossorigin="anonymous"
      is:inline
    />
  )
}

<!-- Sticky footer ad close button -->
<script is:inline data-pt-skip>
  document.addEventListener('click', function (e) {
    var btn = e.target && e.target.closest && e.target.closest('[data-close-sticky]');
    if (btn) {
      var sticky = btn.closest('.ad--sticky');
      if (sticky) sticky.classList.add('ad--sticky-hidden');
    }
  });
</script>
