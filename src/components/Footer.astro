---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import SocialIcon from './SocialIcon.astro';
import Newsletter from './Newsletter.astro';
import { getCategories, getSiteConsts } from '../lib/cms';

const [siteConsts, categories] = await Promise.all([getSiteConsts(), getCategories()]);
const { SITE, FOOTER_LEGAL, FOOTER_COMPANY, SOCIAL_NETWORKS, SOCIAL_FOLLOW } = siteConsts;

const year = 2026;
---

<footer class="site-footer">
  <div class="container footer__newsletter">
    <Newsletter variant="footer" />
  </div>

  <div class="container footer__grid">
    <div class="footer__brand">
      <Logo tone="light" />
      <p class="footer__blurb">
        Free, science-backed health calculators and wellness tools. Private by
        design — your numbers never leave your device, and no account is needed.
      </p>
      <a href="/contact" class="footer__contact">
        <Icon name="arrow-right" size={16} /> Contact us
      </a>

      <div class="footer__follow">
        <span class="footer__follow-label">Follow us</span>
        <div class="social-row">
          {
            SOCIAL_FOLLOW.map((s) => {
              const net = SOCIAL_NETWORKS[s.network];
              return (
                <a
                  class="social-btn social-btn--on-dark"
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  style={`--brand:${net.color}`}
                  aria-label={`Follow us on ${net.label}`}
                  title={net.label}
                >
                  <SocialIcon name={s.network} size={18} />
                </a>
              );
            })
          }
        </div>
      </div>
    </div>

    <nav class="footer__col" aria-label="Tool categories">
      <h2 class="footer__heading">Categories</h2>
      <ul>
        {
          categories.map((c) => (
            <li>
              <a href={`/${c.slug}`}>{c.name}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Company">
      <h2 class="footer__heading">Company</h2>
      <ul>
        {
          FOOTER_COMPANY.map((l) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Legal">
      <h2 class="footer__heading">Legal</h2>
      <ul>
        {
          FOOTER_LEGAL.map((l) => (
            <li>
              <a href={l.href}>{l.label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="container footer__disclaimer">
    <p>
      <strong>Not medical advice.</strong> The tools and content on {SITE.name} are
      for general informational and educational purposes only and are not a substitute
      for professional medical advice, diagnosis, or treatment. Always consult a
      qualified healthcare provider with questions about your health.
    </p>
  </div>

  <div class="container footer__bottom">
    <p>&copy; {year} {SITE.name}. All rights reserved.</p>
    <p class="footer__sub">{SITE.tagline} · Built for the US, UK, Canada &amp; Australia.</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--dark);
    color: #cbd5e1;
    padding-block: clamp(3rem, 6vw, 4.5rem) 2rem;
    margin-top: auto;
  }
  .footer__newsletter {
    max-width: 640px;
    margin-bottom: clamp(2.25rem, 5vw, 3rem);
    padding-bottom: clamp(2.25rem, 5vw, 3rem);
    border-bottom: 1px solid rgba(148, 163, 184, 0.18);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 1.6fr repeat(3, 1fr);
    gap: clamp(2rem, 5vw, 3.5rem);
  }
  .footer__blurb {
    margin-top: 1.1rem;
    max-width: 36ch;
    color: #94a3b8;
    font-size: 0.95rem;
  }
  .footer__contact {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.1rem;
    color: var(--green-accent);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
  }
  .footer__follow {
    margin-top: 1.75rem;
  }
  .footer__follow-label {
    display: block;
    margin-bottom: 0.7rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
  }
  .footer__heading {
    font-family: var(--font-display);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin-bottom: 1rem;
  }
  .footer__col ul {
    display: grid;
    gap: 0.65rem;
  }
  .footer__col a {
    color: #94a3b8;
    font-size: 0.95rem;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer__col a:hover {
    color: #fff;
    text-decoration: none;
  }

  .footer__disclaimer {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }
  .footer__disclaimer p {
    border: 1px solid rgba(148, 163, 184, 0.2);
    background: rgba(148, 163, 184, 0.06);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    font-size: 0.85rem;
    color: #94a3b8;
    line-height: 1.6;
  }
  .footer__disclaimer strong {
    color: #e2e8f0;
  }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(148, 163, 184, 0.18);
    font-size: 0.85rem;
    color: #64748b;
  }
  .footer__sub {
    color: #64748b;
  }

  @media (max-width: 760px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }
  @media (max-width: 460px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
