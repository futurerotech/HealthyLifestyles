---
/**
 * Email-newsletter signup (footer + end of articles). Submits via fetch() to the
 * local /api/subscribe Astro endpoint, which proxies securely to the Payload CMS.
 * No page reload, no new tab, no third-party script.
 */
import Icon from './Icon.astro';

interface Props {
  variant?: 'footer' | 'inline';
}
const { variant = 'inline' } = Astro.props;
const inputId = `nl-email-${variant}`;
---

<form
  class:list={['newsletter', `newsletter--${variant}`]}
  data-newsletter
>
  <div class="newsletter__copy">
    <strong>Get new calculators &amp; guides</strong>
    <span>Occasional, evidence-based wellness tips. No spam — unsubscribe anytime.</span>
  </div>
  <div class="newsletter__field">
    <label class="sr-only" for={inputId}>Email address</label>
    <input
      id={inputId}
      type="email"
      name="email"
      required
      placeholder="you@example.com"
      autocomplete="email"
    />
    <button type="submit">
      Subscribe <Icon name="arrow-right" size={16} />
    </button>
  </div>
  <p class="newsletter__status" data-newsletter-status role="status" aria-live="polite"></p>
</form>

<script>
  document.querySelectorAll<HTMLFormElement>('form[data-newsletter]').forEach((form) => {
    const input = form.querySelector<HTMLInputElement>('input[type="email"]');
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const status = form.querySelector<HTMLElement>('[data-newsletter-status]');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (input?.value || '').trim();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        if (status) {
          status.textContent = 'Please enter a valid email address.';
          status.dataset.state = 'error';
        }
        return;
      }

      if (button) button.disabled = true;
      if (status) {
        status.textContent = 'Subscribing…';
        status.dataset.state = 'loading';
      }

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email }),
        });
        const data = await res.json().catch(() => ({ ok: false }));

        if (res.ok && data.ok) {
          if (status) {
            status.textContent = 'Thanks for subscribing!';
            status.dataset.state = 'success';
          }
          if (input) input.value = '';
        } else {
          if (status) {
            status.textContent = data.message || 'Something went wrong. Please try again.';
            status.dataset.state = 'error';
          }
        }
      } catch (err) {
        if (status) {
          status.textContent = 'Network error. Please try again.';
          status.dataset.state = 'error';
        }
      } finally {
        if (button) button.disabled = false;
      }
    });
  });
</script>

<style>
  .newsletter {
    display: grid;
    gap: 0.9rem;
  }
  .newsletter__copy strong {
    display: block;
    font-family: var(--font-display);
    font-size: 1.05rem;
  }
  .newsletter__copy span {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.9rem;
    color: var(--muted);
  }
  .newsletter__field {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .newsletter__field input {
    flex: 1 1 220px;
    min-width: 0;
    padding: 0.7rem 0.95rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-pill);
    background: #fff;
    font: inherit;
    color: var(--ink);
  }
  .newsletter__field input:focus-visible {
    outline: none;
    border-color: var(--green-accent);
    box-shadow: var(--focus-ring);
  }
  .newsletter__field button {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.7rem 1.2rem;
    border: 0;
    border-radius: var(--radius-pill);
    background: var(--green-primary);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.92rem;
    cursor: pointer;
    transition: background-color 0.15s ease;
  }
  .newsletter__field button:hover {
    background: var(--green-700);
  }
  .newsletter__field button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter__status {
    margin: 0;
    font-size: 0.88rem;
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .newsletter__status[data-state] {
    opacity: 1;
  }
  .newsletter__status[data-state='success'] {
    color: var(--green-accent);
  }
  .newsletter__status[data-state='error'] {
    color: #ef4444;
  }
  .newsletter__status[data-state='loading'] {
    color: var(--muted);
  }

  /* Footer variant: lighter text on the dark footer. */
  .newsletter--footer .newsletter__copy strong {
    color: #fff;
  }
  .newsletter--footer .newsletter__copy span {
    color: #94a3b8;
  }
  .newsletter--footer .newsletter__field input {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(148, 163, 184, 0.25);
    color: #fff;
  }
  .newsletter--footer .newsletter__field input::placeholder {
    color: #94a3b8;
  }
  .newsletter--footer .newsletter__status[data-state='loading'] {
    color: #94a3b8;
  }

  /* Inline (article) variant: card framing. */
  .newsletter--inline {
    background: var(--mint-50);
    border: 1px solid #d1fae5;
    border-radius: var(--radius);
    padding: 1.4rem 1.5rem;
    margin: 2.5rem 0;
  }
</style>
