---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---

<nav class="crumbs" aria-label="Breadcrumb">
  <ol>
    {
      items.map((c, i) => (
        <li>
          {c.href && i < items.length - 1 ? (
            <a href={c.href}>{c.label}</a>
          ) : (
            <span aria-current="page">{c.label}</span>
          )}
          {i < items.length - 1 && <span class="crumbs__sep" aria-hidden="true">/</span>}
        </li>
      ))
    }
  </ol>
</nav>

<style>
  .crumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
  }
  .crumbs li {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .crumbs a {
    color: var(--muted);
    font-weight: 600;
  }
  .crumbs a:hover {
    color: var(--green-700);
  }
  .crumbs [aria-current='page'] {
    color: var(--ink);
    font-weight: 700;
  }
  .crumbs__sep {
    color: var(--border);
  }
</style>
