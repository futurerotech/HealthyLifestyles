---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { NAV_LINKS } from '../consts';
import { CATEGORIES } from '../data/categories';
import { getToolsByCategory } from '../data/tools';

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');

// "Calculators & Tools" is active on /tools, any tool page, or any category hub.
const catSlugs = CATEGORIES.map((c) => c.slug);
const onToolsSection =
  path === '/tools' ||
  path.startsWith('/tools/') ||
  catSlugs.some((s) => path === `/${s}` || path.startsWith(`/${s}/`));

// Top tools per category for the mega-menu (popular first, max 3, live only).
const megaCats = CATEGORIES.map((c) => ({
  ...c,
  top: [...getToolsByCategory(c.id).filter((t) => t.live)]
    .sort((a, b) => (b.popular ? 1 : 0) - (a.popular ? 1 : 0))
    .slice(0, 3),
}));

// Everything except the "Calculators & Tools" trigger.
const secondaryLinks = NAV_LINKS.filter((l) => l.href !== '/tools');
const navIcons: Record<string, string> = {
  '/wellness-hub': 'book',
  '/health-score': 'shield',
  '/ai-assistant': 'zap',
  '/about': 'star',
};
---

<header class="site-header" id="site-header" data-state="top">
  <div class="container header__inner">
    <Logo tone="dark" class="header__logo" />

    <nav class="header__nav" aria-label="Primary">
      <ul class="header__nav-list">
        <li class="nav-item nav-item--mega">
          <button
            type="button"
            id="mega-trigger"
            class:list={['nav-link nav-trigger', { 'is-active': onToolsSection }]}
            aria-expanded="false"
            aria-haspopup="true"
            aria-controls="mega-menu"
          >
            Calculators &amp; Tools
            <Icon name="chevron-down" size={16} class="nav-trigger__chev" />
          </button>

          <div class="mega" id="mega-menu" role="region" aria-label="Calculators & Tools">
            <div class="mega__inner container">
              <ul class="mega__grid">
                {
                  megaCats.map((c) => (
                    <li class="mega__cat">
                      <a href={`/${c.slug}`} class="mega__cat-head">
                        <span class="mega__cat-icon" style={`--c:${c.color}`}>
                          <Icon name={c.icon} size={18} />
                        </span>
                        <span class="mega__cat-name">{c.name}</span>
                      </a>
                      <ul class="mega__tools">
                        {c.top.map((t) => (
                          <li>
                            <a href={`/tools/${t.slug}`} class="mega__tool">{t.title}</a>
                          </li>
                        ))}
                      </ul>
                    </li>
                  ))
                }
              </ul>
              <a href="/tools" class="mega__all">View all tools <Icon name="arrow-right" size={16} /></a>
            </div>
          </div>
        </li>

        {
          secondaryLinks.map((link) => (
            <li class="nav-item">
              <a
                href={link.href}
                class:list={['nav-link', { 'is-active': isActive(link.href) }]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="header__actions">
      <a href="/tools" class="btn btn-outline header__view-all">View All Tools</a>
      <a href="/health-score" class="btn btn-primary header__cta">Get My Health Score</a>
    </div>

    <button
      type="button"
      class="header__burger"
      id="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <Icon name="menu" size={26} />
    </button>
  </div>
</header>

<!-- Mobile slide-in panel -->
<div class="mobile-overlay" id="mobile-overlay"></div>
<aside class="mobile-panel" id="mobile-menu" role="dialog" aria-modal="true" aria-label="Menu">
  <div class="mobile-panel__head">
    <Logo tone="dark" />
    <button type="button" class="mobile-panel__close" id="mobile-close" aria-label="Close menu">
      <Icon name="close" size={24} />
    </button>
  </div>

  <div class="mobile-panel__scroll">
    <p class="mobile-group__title" id="m-tools">Calculators &amp; Tools</p>
    <ul class="mobile-cats" aria-labelledby="m-tools">
      {
        CATEGORIES.map((c) => (
          <li>
            <a href={`/${c.slug}`} class="mobile-cat">
              <span class="mobile-cat__icon" style={`--c:${c.color}`}>
                <Icon name={c.icon} size={18} />
              </span>
              <span>{c.name}</span>
              <Icon name="arrow-right" size={16} class="mobile-cat__chev" />
            </a>
          </li>
        ))
      }
    </ul>
    <a href="/tools" class="mobile-alltools">View all tools <Icon name="arrow-right" size={16} /></a>

    <p class="mobile-group__title" id="m-explore">Explore</p>
    <ul class="mobile-links" aria-labelledby="m-explore">
      {
        secondaryLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={['mobile-link', { 'is-active': isActive(link.href) }]}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              <span class="mobile-link__icon"><Icon name={navIcons[link.href] ?? 'arrow-right'} size={18} /></span>
              <span>{link.label}</span>
              <Icon name="arrow-right" size={16} class="mobile-link__chev" />
            </a>
          </li>
        ))
      }
    </ul>
  </div>

  <div class="mobile-panel__cta">
    <a href="/health-score" class="btn btn-primary btn-lg">Get My Health Score <Icon name="arrow-right" size={18} /></a>
  </div>
</aside>

<style>
  /* ---------- Sticky bar ---------- */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: saturate(180%) blur(14px);
    -webkit-backdrop-filter: saturate(180%) blur(14px);
    border-bottom: 1px solid transparent;
    transition: box-shadow 0.28s ease, border-color 0.28s ease, background 0.28s ease;
  }
  .site-header[data-state='scrolled'] {
    background: rgba(255, 255, 255, 0.86);
    border-bottom-color: var(--border);
    box-shadow: 0 6px 24px -14px rgba(2, 6, 23, 0.28), var(--shadow-sm);
  }

  .header__inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    height: var(--header-h);
    transition: height 0.28s ease;
  }
  .site-header[data-state='scrolled'] .header__inner {
    height: 60px;
  }
  .header__logo {
    flex-shrink: 0;
  }

  /* ---------- Desktop nav ---------- */
  .header__nav {
    margin-inline: auto;
  }
  .header__nav-list {
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }
  .nav-item {
    display: flex;
  }
  .nav-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    white-space: nowrap;
    padding: 0.55rem 0.85rem;
    font-family: inherit;
    font-weight: 600;
    font-size: 0.95rem;
    line-height: 1;
    color: var(--ink);
    background: none;
    border: 0;
    cursor: pointer;
    transition: color 0.15s ease;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.3rem;
    height: 2px;
    border-radius: 2px;
    background: var(--green-primary);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.15s ease;
  }
  .nav-link:hover,
  .nav-link.is-active {
    color: var(--green-700);
    text-decoration: none;
  }
  .nav-link:hover::after,
  .nav-link:focus-visible::after,
  .nav-link.is-active::after {
    transform: scaleX(1);
  }
  .nav-link:focus-visible {
    outline: 2px solid var(--green-primary);
    outline-offset: 3px;
    border-radius: 6px;
  }
  .nav-trigger__chev {
    transition: transform 0.2s ease;
  }
  .nav-item--mega[data-open='true'] .nav-trigger__chev {
    transform: rotate(180deg);
  }

  /* ---------- Mega-menu ---------- */
  .nav-item--mega {
    position: static;
  }
  .mega {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s linear 0.18s;
  }
  .nav-item--mega[data-open='true'] .mega {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
    transition: opacity 0.18s ease, transform 0.18s ease, visibility 0s;
  }
  .mega__inner {
    margin-top: 0.5rem;
    background: rgba(255, 255, 255, 0.98);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: 0 24px 60px -20px rgba(2, 6, 23, 0.3);
    padding: 1.5rem;
  }
  .mega__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem 1.75rem;
  }
  .mega__cat {
    padding: 0.5rem 0;
  }
  .mega__cat-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.98rem;
    color: var(--ink);
    padding: 0.3rem 0.4rem;
    border-radius: var(--radius-sm);
  }
  .mega__cat-head:hover {
    text-decoration: none;
    background: var(--mint-50);
    color: var(--green-700);
  }
  .mega__cat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 9px;
    color: var(--c);
    background: color-mix(in srgb, var(--c) 14%, white);
    flex-shrink: 0;
  }
  .mega__tools {
    margin: 0.15rem 0 0 2.6rem;
    display: grid;
    gap: 0.1rem;
  }
  .mega__tool {
    display: block;
    padding: 0.28rem 0.4rem;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.35;
  }
  .mega__tool:hover {
    text-decoration: none;
    color: var(--green-700);
    background: var(--mint-50);
  }
  .mega__all {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1.1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    width: 100%;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--green-700);
  }
  .mega__all:hover {
    text-decoration: none;
    gap: 0.6rem;
  }

  /* ---------- CTAs ---------- */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-shrink: 0;
  }
  .header__actions .btn {
    height: 42px;
    padding-inline: 1.1rem;
    font-size: 0.92rem;
  }
  .header__cta {
    box-shadow: 0 8px 22px -8px color-mix(in srgb, var(--green-primary) 70%, transparent);
  }
  .header__cta:hover {
    box-shadow: 0 10px 26px -8px color-mix(in srgb, var(--green-primary) 80%, transparent);
  }

  /* ---------- Burger ---------- */
  .header__burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-left: auto;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--ink);
    cursor: pointer;
  }
  .header__burger:hover {
    border-color: var(--green-accent);
    color: var(--green-700);
  }
  .header__burger:focus-visible {
    outline: 2px solid var(--green-primary);
    outline-offset: 2px;
  }

  /* ---------- Mobile panel ---------- */
  .mobile-overlay {
    position: fixed;
    inset: 0;
    z-index: 110;
    background: rgba(2, 6, 23, 0.45);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.25s ease, visibility 0s linear 0.25s;
  }
  .mobile-overlay.is-open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.25s ease;
  }
  .mobile-panel {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: 120;
    width: min(360px, 86vw);
    display: flex;
    flex-direction: column;
    background: #fff;
    box-shadow: -20px 0 50px -20px rgba(2, 6, 23, 0.4);
    transform: translateX(100%);
    visibility: hidden;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1), visibility 0s linear 0.28s;
  }
  .mobile-panel.is-open {
    transform: translateX(0);
    visibility: visible;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .mobile-panel__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border);
  }
  .mobile-panel__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: var(--ink);
    cursor: pointer;
  }
  .mobile-panel__close:hover {
    border-color: var(--green-accent);
    color: var(--green-700);
  }
  .mobile-panel__close:focus-visible,
  .mobile-cat:focus-visible,
  .mobile-link:focus-visible,
  .mobile-alltools:focus-visible {
    outline: 2px solid var(--green-primary);
    outline-offset: 2px;
  }
  .mobile-panel__scroll {
    flex: 1;
    overflow-y: auto;
    padding: 1rem 1.25rem 1.5rem;
    -webkit-overflow-scrolling: touch;
  }
  .mobile-group__title {
    margin: 0.5rem 0 0.6rem;
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .mobile-group__title:not(:first-child) {
    margin-top: 1.5rem;
  }
  .mobile-cats {
    display: grid;
    gap: 0.15rem;
  }
  .mobile-cat,
  .mobile-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-height: 44px;
    padding: 0.6rem 0.65rem;
    border-radius: var(--radius);
    color: var(--ink);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .mobile-cat:hover,
  .mobile-link:hover {
    text-decoration: none;
    background: var(--mint-50);
  }
  .mobile-link.is-active {
    background: var(--mint-50);
    color: var(--green-700);
  }
  .mobile-cat__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    color: var(--c);
    background: color-mix(in srgb, var(--c) 14%, white);
    flex-shrink: 0;
  }
  .mobile-link__icon {
    display: inline-flex;
    color: var(--green-primary);
  }
  .mobile-cat__chev,
  .mobile-link__chev {
    margin-left: auto;
    color: var(--muted);
  }
  .mobile-alltools {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0.75rem 0 0 0.65rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--green-700);
  }
  .mobile-panel__cta {
    padding: 1rem 1.25rem;
    border-top: 1px solid var(--border);
  }
  .mobile-panel__cta .btn {
    width: 100%;
  }

  /* ---------- Breakpoints ---------- */
  @media (max-width: 1120px) {
    .header__view-all {
      display: none;
    }
  }
  @media (max-width: 980px) {
    .header__nav,
    .header__actions {
      display: none;
    }
    .header__burger {
      display: inline-flex;
    }
  }

  /* ---------- Reduced motion ---------- */
  @media (prefers-reduced-motion: reduce) {
    .site-header,
    .header__inner,
    .nav-link,
    .nav-link::after,
    .nav-trigger__chev,
    .mega,
    .mobile-overlay,
    .mobile-panel {
      transition: none !important;
    }
    .mega {
      transform: none;
    }
  }
</style>

<script>
  // ---- Compact-on-scroll ----
  const header = document.getElementById('site-header');
  if (header) {
    let ticking = false;
    const update = () => {
      header.dataset.state = window.scrollY > 12 ? 'scrolled' : 'top';
      ticking = false;
    };
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
    update();
  }

  // ---- Mega-menu (hover + full keyboard) ----
  const megaItem = document.querySelector<HTMLElement>('.nav-item--mega');
  const megaTrigger = document.getElementById('mega-trigger');
  if (megaItem && megaTrigger) {
    let closeTimer: number | undefined;
    const setMega = (open: boolean) => {
      window.clearTimeout(closeTimer);
      megaItem.dataset.open = String(open);
      megaTrigger.setAttribute('aria-expanded', String(open));
    };
    megaItem.addEventListener('mouseenter', () => setMega(true));
    megaItem.addEventListener('mouseleave', () => {
      closeTimer = window.setTimeout(() => setMega(false), 120);
    });
    megaTrigger.addEventListener('click', () =>
      setMega(megaItem.dataset.open !== 'true'),
    );
    // Open when focus enters; close when focus leaves the whole item.
    megaItem.addEventListener('focusin', () => setMega(true));
    megaItem.addEventListener('focusout', (e) => {
      if (!megaItem.contains(e.relatedTarget as Node)) setMega(false);
    });
    // Escape closes and returns focus to the trigger.
    megaItem.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape' && megaItem.dataset.open === 'true') {
        setMega(false);
        (megaTrigger as HTMLButtonElement).focus();
      }
    });
    // Outside click/focus closes.
    document.addEventListener('click', (e) => {
      if (megaItem.dataset.open === 'true' && !megaItem.contains(e.target as Node)) setMega(false);
    });
  }

  // ---- Mobile slide-in panel (focus trap, scroll lock, Escape) ----
  const burger = document.getElementById('nav-toggle');
  const panel = document.getElementById('mobile-menu');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('mobile-close');
  if (burger && panel && overlay) {
    const focusables = () =>
      Array.from(
        panel.querySelectorAll<HTMLElement>('a[href], button:not([disabled])'),
      ).filter((el) => el.offsetParent !== null);

    let lastFocused: HTMLElement | null = null;

    const setOpen = (open: boolean) => {
      panel.classList.toggle('is-open', open);
      overlay.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', String(open));
      document.body.style.overflow = open ? 'hidden' : '';
      if (open) {
        lastFocused = document.activeElement as HTMLElement;
        const f = focusables();
        (closeBtn ?? f[0])?.focus();
      } else {
        lastFocused?.focus();
      }
    };

    burger.addEventListener('click', () =>
      setOpen(burger.getAttribute('aria-expanded') !== 'true'),
    );
    closeBtn?.addEventListener('click', () => setOpen(false));
    overlay.addEventListener('click', () => setOpen(false));
    // Close after following any link.
    panel.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) setOpen(false);
    });

    document.addEventListener('keydown', (e) => {
      const ev = e as KeyboardEvent;
      if (burger.getAttribute('aria-expanded') !== 'true') return;
      if (ev.key === 'Escape') {
        setOpen(false);
      } else if (ev.key === 'Tab') {
        const f = focusables();
        if (f.length === 0) return;
        const first = f[0];
        const last = f[f.length - 1];
        if (ev.shiftKey && document.activeElement === first) {
          ev.preventDefault();
          last.focus();
        } else if (!ev.shiftKey && document.activeElement === last) {
          ev.preventDefault();
          first.focus();
        }
      }
    });
  }
</script>
