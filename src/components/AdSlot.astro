---
/**
 * Ad slot — renders a single ad unit driven by the Ad Management global.
 *
 * - Renders ONLY when there's a real unit (AdSense slot id, custom code, or an
 *   affiliate banner). Empty slots render nothing — no gray box, no
 *   "Advertisement" placeholder, no reserved height (it collapses).
 * - The <ins> is followed immediately by its own push so AdSense fills it as
 *   soon as it renders. Unfilled units collapse via the data-ad-status CSS.
 * - NEVER uses Partytown for ads (Partytown breaks AdSense iframe injection):
 *   the library loads main-thread from <AdsLoader>, and the push is data-pt-skip.
 */

import { ADS } from '../consts';
import { getAdConfig } from '../lib/ad-config';

const { placement, class: cls } = Astro.props;

const adConfig = await getAdConfig();
const cmsPresent = !!adConfig;
const slot = adConfig?.slots?.find((s) => s.placement === placement) || null;

// STRICT CMS obedience. When the CMS is reachable, this slot is governed ENTIRELY
// by its CMS entry: a missing OR disabled slot renders absolutely nothing — no
// <ins>, no wrapper, no push. The static consts (ADS.*) are used ONLY as an
// offline fallback when the CMS itself is unreachable at build time.
const slotEnabled = cmsPresent ? slot?.enabled === true : true;
const masterOn = adConfig ? adConfig.adsenseEnabled !== false : true;

const clientId = adConfig?.adsenseClient || ADS.client;
const validClient = !!clientId && /^ca-pub-\d+$/.test(clientId);
const slotId = slotEnabled ? slot?.adsenseSlotId || (ADS.slots as Record<string, string>)[placement] || '' : '';

const hasCustom = slotEnabled ? slot?.customCode : undefined;
const affiliate =
  slotEnabled && slot?.affiliateBanner?.url && slot?.affiliateBanner?.image?.url ? slot.affiliateBanner : null;
const showIns = masterOn && validClient && !!slotId && !hasCustom && !affiliate;

const sticky = placement === 'stickyFooter';

// Render ONLY when the slot is enabled in the CMS AND has something real to show.
const hasAd = slotEnabled && (showIns || !!hasCustom || !!affiliate);
---

{hasAd && (
<aside
  class:list={['ad', `ad--${placement}`, sticky ? 'ad--sticky' : '', cls]}
  role="complementary"
  aria-label="Advertisement"
>
  {sticky && (
    <button class="ad__close" data-close-sticky type="button" aria-label="Close advertisement">&times;</button>
  )}

  {affiliate ? (
    <a href={affiliate.url} target="_blank" rel="noopener sponsored" class="ad__affiliate">
      <img
        src={affiliate.image.url}
        alt={affiliate.alt || 'Advertisement'}
        width={affiliate.width || undefined}
        height={affiliate.height || undefined}
        loading="lazy"
      />
    </a>
  ) : hasCustom ? (
    <Fragment set:html={hasCustom} />
  ) : (
    <>
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client={clientId}
        data-ad-slot={slotId}
        data-ad-format="auto"
        data-full-width-responsive="true"
      />
      <script is:inline data-pt-skip>(adsbygoogle = window.adsbygoogle || []).push({});</script>
    </>
  )}
</aside>
)}

<style>
  /* Invisible/collapsed by default — only takes space once a real ad fills it. */
  .ad {
    position: relative;
    display: block;
    margin-block: clamp(1.5rem, 3vw, 2.25rem);
  }
  .adsbygoogle {
    display: block;
    width: 100%;
  }
  /* Collapse an unfilled AdSense unit (and its wrapper) — no empty box. */
  ins.adsbygoogle[data-ad-status='unfilled'] {
    display: none !important;
  }
  .ad:has(ins.adsbygoogle[data-ad-status='unfilled']) {
    display: none !important;
    margin: 0 !important;
  }

  .ad--sticky {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 100;
    margin: 0;
    background: #fff;
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease;
  }
  .ad--sticky-hidden { transform: translateY(100%); }
  .ad__close {
    position: absolute;
    top: 0; right: 0;
    z-index: 2;
    width: 28px; height: 28px;
    border: none;
    background: var(--surface);
    border-radius: 0 0 0 4px;
    font-size: 1.1rem;
    line-height: 1;
    cursor: pointer;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ad__close:hover { color: var(--text); background: var(--surface-2); }

  .ad__affiliate { display: block; width: 100%; }
  .ad__affiliate img { display: block; width: 100%; height: auto; object-fit: contain; }

  /* Sidebar ads hidden on mobile (no room). */
  @media (max-width: 960px) {
    .ad--sidebar { display: none; }
  }
</style>
