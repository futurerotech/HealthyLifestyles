---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from './Breadcrumb.astro';
import Icon from './Icon.astro';
import ToolIcon from './ToolIcon.astro';
import ShareBar from './ShareBar.astro';
import PrintButton from './PrintButton.astro';
import Byline from './Byline.astro';
import EmbedCode from './EmbedCode.astro';
import Logo from './Logo.astro';
import AdSlot from './AdSlot.astro';
import Calculator from '../islands/Calculator.tsx';
import SleepCalculator from '../islands/SleepCalculator.tsx';
import DateCalculator from '../islands/DateCalculator.tsx';
import PaceCalculator from '../islands/PaceCalculator.tsx';
import QuizCalculator from '../islands/QuizCalculator.tsx';
import BreathingTimer from '../islands/BreathingTimer.tsx';
import MealPlanGenerator from '../islands/MealPlanGenerator.tsx';
import LifestyleAge from '../islands/LifestyleAge.tsx';
import HealthspanScore from '../islands/HealthspanScore.tsx';
import { getEngine } from '../lib/toolEngine';
import StrengthProgram from '../islands/StrengthProgram.tsx';
import CaffeineCurfew from '../islands/CaffeineCurfew.tsx';
import MusclePreservation from '../islands/MusclePreservation.tsx';
import SittingReversal from '../islands/SittingReversal.tsx';
import Fasting from '../islands/Fasting.tsx';
import Chronotype from '../islands/Chronotype.tsx';
import WalkItOff from '../islands/WalkItOff.tsx';
import WeightTimeline from '../islands/WeightTimeline.tsx';
import CaffeineTracker from '../islands/CaffeineTracker.tsx';
import FoodSymptomDiary from '../islands/FoodSymptomDiary.tsx';
import HRVLog from '../islands/HRVLog.tsx';
import RecipeAnalyzer from '../islands/RecipeAnalyzer.tsx';
import LeadCTA from './LeadCTA.astro';
import RelatedTools from './RelatedTools.astro';
import '../styles/calculator.css';
import { getSiteConsts, getRelatedTools } from '../lib/cms';
import { getCategory } from '../lib/cms';
import { getArticlesForTool, resolveAuthor, REVIEWER_SLUG } from '../lib/cms';
import type { Tool } from '../data/tools';
import { getAffiliates } from '../data/affiliates';
import type { ToolContent } from '../data/content-types';

interface Props {
  tool: Tool;
  content: ToolContent;
}

const { tool, content } = Astro.props;
const origin = Astro.site ?? new URL('https://www.healthylifesstyles.com');
const orgId = `${origin.href}#org`;

const [siteConsts, category, related, guides, authorEntity, reviewerEntity] = await Promise.all([
  getSiteConsts(),
  getCategory(tool.category).then((c) => c!),
  getRelatedTools(tool.slug, 4),
  getArticlesForTool(tool.slug, 3),
  resolveAuthor('editorial-team'),
  resolveAuthor(REVIEWER_SLUG),
]);
const SITE = siteConsts.SITE;
const EDITORIAL = siteConsts.EDITORIAL;
const affiliate = getAffiliates(tool.slug);

// Result-level safety line (YMYL). Names the relevant authority for sensitive topics.
const RESULT_AUTHORITY: Record<string, string> = {
  'womens-health': ' For pregnancy and cycle decisions, follow your OB-GYN — guidance reflects the American College of Obstetricians and Gynecologists (ACOG).',
  'heart-vitals': ' Categories follow the American Heart Association (AHA).',
  'health-risk': ' Based on CDC and World Health Organization (WHO) guidance — only a clinician can assess your real risk.',
};
const resultAuthority = RESULT_AUTHORITY[tool.category] ?? '';

// Which calculator island powers this tool — the ONE shared mapping in
// lib/toolEngine.ts (this used to be a duplicated inline ternary chain, and
// the two copies drifting apart made new coded tools silently fall back to
// the numeric engine here).
const engine = getEngine(tool);

const pageUrl = new URL(Astro.url.pathname, origin).href.replace(/\/$/, '');

// Clean report name for the print/PDF title + filename (drops the tool-type suffix).
const reportName = tool.title.replace(
  /\s+(Calculator|Checker|Tracker|Quiz|Test|Builder|Generator|Timer|Planner)$/i,
  '',
);
const reportTitle = `${reportName} Result — ${SITE.name}`;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: category.name, href: `/${category.slug}` },
  { label: tool.title },
];

// ---- JSON-LD ----
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(c.href, origin).href.replace(/\/$/, '') } : {}),
  })),
};

function authorLd(a: typeof authorEntity) {
  return {
    '@type': a.schemaType,
    '@id': new URL(`/author/${a.slug}`, origin).href,
    name: a.name,
    url: new URL(`/author/${a.slug}`, origin).href,
    ...(a.credential ? { credential: a.credential } : {}),
    ...(a.schemaType === 'Person' ? { jobTitle: a.role, worksFor: { '@id': orgId } } : {}),
  };
}

const appLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  '@id': `${pageUrl}#app`,
  name: tool.title,
  url: pageUrl,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any (web browser)',
  description: content.metaDescription,
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author: authorLd(authorEntity),
  publisher: { '@id': orgId },
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  // The Quick-answer box leads the FAQPage schema so assistants can lift the
  // page's core answer directly (AI-citation readiness).
  mainEntity: [
    ...(content.directAnswer
      ? [{
          '@type': 'Question',
          name: content.directAnswer.question,
          acceptedAnswer: { '@type': 'Answer', text: content.directAnswer.answer },
        }]
      : []),
    ...content.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  ],
};

// Health content → MedicalWebPage with review info for E-E-A-T.
const medicalLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalWebPage',
  '@id': `${pageUrl}#medical`,
  name: tool.title,
  url: pageUrl,
  description: content.metaDescription,
  inLanguage: 'en',
  lastReviewed: EDITORIAL.lastReviewed,
  author: authorLd(authorEntity),
  reviewedBy: authorLd(reviewerEntity),
  audience: { '@type': 'MedicalAudience', audienceType: 'https://schema.org/Patient' },
  isPartOf: { '@type': 'WebSite', '@id': origin.href },
  // CMS semantic entities → DefinedTerm `about` (same pattern as articles):
  // turns stored entities into a real topical-authority signal for search/AI.
  ...((tool.semanticEntities?.length ?? 0) > 0
    ? {
        about: tool.semanticEntities!.map((e) => ({
          '@type': 'DefinedTerm',
          name: e.term,
          ...(e.url ? { url: e.url } : {}),
        })),
      }
    : {}),
};
---

<BaseLayout
  title={content.seoTitle}
  description={content.metaDescription}
  image={`/og/tools/${tool.slug}.png`}
  type="website"
  jsonLd={[breadcrumbLd, appLd, faqLd, medicalLd]}
>
  <article class="tool">
    <!-- Branded header shown only when printing / saving to PDF -->
    <div class="print-only print-sheet-head">
      <div class="print-band">
        <Logo />
        <div class="print-band__meta">
          <span class="print-band__url">{pageUrl.replace(/^https?:\/\//, '')}</span>
          <span class="print-date" data-print-date></span>
        </div>
      </div>
      <h1 class="print-sheet-head__tool">{tool.title}</h1>
      <p class="print-sheet-head__intro">{content.intro}</p>
    </div>

    <!-- Header -->
    <header class="tool__header section-mint">
      <div class="container">
        <Breadcrumb items={breadcrumbItems} />
        <div class="tool__icon-wrap">
          <ToolIcon icon={tool.icon} gradient={tool.gradient} size={56} />
        </div>
        <span class="tool__cat-pill" style={`--c:${category.color}`}>
          <Icon name={category.icon} size={16} /> {category.name}
        </span>
        <h1>{tool.title}</h1>
        <p class="lead">{content.intro}</p>
        <Byline author="editorial-team" updated={EDITORIAL.lastReviewed} class="tool__byline" />
        {
          content.notice && (
            <p class="tool__notice" role="note">
              <Icon name="shield" size={20} />
              <span>{content.notice}</span>
            </p>
          )
        }
      </div>
    </header>

    <!-- Quick answer — the page's core question answered directly (AI-citation
         readiness: liftable by assistants/snippets; also leads the FAQPage LD). -->
    {content.directAnswer && (
      <section class="container" aria-labelledby="quick-answer-title">
        <div class="tool__answer">
          <h2 id="quick-answer-title" class="tool__answer-q">{content.directAnswer.question}</h2>
          <p class="tool__answer-a">{content.directAnswer.answer}</p>
        </div>
      </section>
    )}

    <!-- Calculator -->
    <section class="container tool__calc" data-tool={tool.slug} aria-label={`${tool.title} tool`}>
      {engine === 'meal' && <MealPlanGenerator client:load />}
      {engine === 'lifestyle-age' && <LifestyleAge client:load />}
      {engine === 'strength' && <StrengthProgram client:load />}
      {engine === 'caffeine' && <CaffeineCurfew client:load />}
      {engine === 'muscle' && <MusclePreservation client:load />}
      {engine === 'sitting' && <SittingReversal client:load />}
      {engine === 'fasting' && <Fasting client:load />}
      {engine === 'chronotype' && <Chronotype client:load />}
      {engine === 'walk-it-off' && <WalkItOff client:load />}
      {engine === 'weight-timeline' && <WeightTimeline client:load />}
      {engine === 'caffeine-tracker' && <CaffeineTracker client:load />}
      {engine === 'sleep' && <SleepCalculator client:visible slug={tool.slug} />}
      {engine === 'date' && <DateCalculator client:visible slug={tool.slug} />}
      {engine === 'pace' && <PaceCalculator client:visible slug={tool.slug} />}
      {engine === 'quiz' && <QuizCalculator client:visible slug={tool.slug} />}
      {engine === 'breathing' && <BreathingTimer client:visible slug={tool.slug} />}
      {engine === 'numeric' && <Calculator client:visible slug={tool.slug} toolName={tool.title} />}
      {engine === 'healthspan' && <HealthspanScore client:visible />}
      {engine === 'diary' && <FoodSymptomDiary client:load />}
      {engine === 'hrv' && <HRVLog client:load />}
      {engine === 'recipe' && <RecipeAnalyzer client:load />}
    </section>

    <!-- Required result-level disclaimer, sized to the tool's YMYL risk tier. -->
    <div class="container">
      <p class:list={['tool__result-note', tool.riskLevel === 'high' && 'tool__result-note--high']} role="note">
        <Icon name="shield" size={16} />
        <span>
          {tool.riskLevel === 'high'
            ? 'This tool is for general education and is not medical advice, diagnosis, or treatment. Do not use it to make health decisions — talk to a qualified professional about your health.'
            : 'This is an educational estimate, not medical advice. Consult a qualified professional.'}
          {resultAuthority}
        </span>
      </p>
    </div>

    <!-- Save & share your result — one cohesive block -->
    <section class="container result-actions" aria-label="Save and share your result">
      <p class="result-actions__title">Save &amp; share your result</p>
      <div class="result-actions__row">
        <div class="result-actions__buttons">
          <PrintButton reportTitle={reportTitle} />
          {
            engine === 'numeric' && (
              <button type="button" class="result-action" data-download-image>
                <span class="result-action__icon"><Icon name="download" size={18} /></span>
                <span class="result-action__spinner" aria-hidden="true" />
                <span class="result-action__label">Download image</span>
              </button>
            )
          }
        </div>
        <span class="result-actions__divider" aria-hidden="true"></span>
        <ShareBar url={pageUrl} title={tool.title} showLabel={false} />
      </div>
    </section>

    <section class="container">
      <LeadCTA toolSlug={tool.slug} toolName={tool.title} placement="afterResult" />
    </section>

    <script>
      // Bridge: the "Download image" button asks the Calculator island (which
      // holds the result data) to render the branded card, and reflects its
      // busy/done state. No-ops on tools without the button.
      const imgBtn = document.querySelector<HTMLButtonElement>('[data-download-image]');
      if (imgBtn) {
        const label = imgBtn.querySelector('.result-action__label');
        const defaultText = label?.textContent || 'Download image';
        let fallback: number | undefined;
        const setBusy = (b: boolean) => {
          imgBtn.classList.toggle('is-busy', b);
          imgBtn.disabled = b;
          if (label) label.textContent = b ? 'Preparing…' : defaultText;
        };
        imgBtn.addEventListener('click', () => {
          setBusy(true);
          document.dispatchEvent(new CustomEvent('hls:download-result-image', { detail: { format: 'square' } }));
          window.clearTimeout(fallback);
          fallback = window.setTimeout(() => setBusy(false), 4000);
        });
        document.addEventListener('hls:result-image-done', () => {
          window.clearTimeout(fallback);
          setBusy(false);
        });
      }
    </script>

    <!-- Ad: after the result block -->
    <div class="container tool__ad">
      <AdSlot placement="afterResult" format="rectangle" />
    </div>

    <div class="container tool__body">
      <div class="tool__content">
        <!-- Supporting content -->
        {
          content.sections.map((s) => (
            <section class="prose">
              <h2>{s.h2}</h2>
              {s.paragraphs?.map((p) => <p>{p}</p>)}
              {s.list && (
                <>
                  {s.list.intro && <p>{s.list.intro}</p>}
                  <ul class="prose__list">
                    {s.list.items.map((item) => (
                      <li>
                        <Icon name="check" size={18} class="prose__check" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </>
              )}
            </section>
          ))
        }

        <!-- Affiliate recommendations (relevant, disclosed) -->
        {
          affiliate && (
            <section class="affil" aria-labelledby="affil-title">
              <h2 id="affil-title">{affiliate.heading}</h2>
              {affiliate.intro && <p class="affil__intro">{affiliate.intro}</p>}
              <p class="affil__ftc">
                <Icon name="shield" size={15} /> As an affiliate we may earn from qualifying purchases — at no extra cost to you.
              </p>
              <ul class="affil__grid">
                {affiliate.items.map((it) => (
                  <li>
                    <a href={it.href} target="_blank" rel="sponsored nofollow noopener">
                      <strong>{it.name}</strong>
                      <span>{it.blurb}</span>
                      <span class="affil__cta">View options <Icon name="arrow-right" size={14} /></span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <!-- Ad: mid-content -->
        <AdSlot placement="midContent" format="rectangle" />

        <!-- FAQ -->
        <section class="prose" aria-labelledby="tool-faq">
          <h2 id="tool-faq">Frequently asked questions</h2>
          <div class="tool__faq">
            {
              content.faq.map((f) => (
                <details>
                  <summary>
                    <span>{f.q}</span>
                    <Icon name="chevron-down" size={20} class="tool__faq-chev" />
                  </summary>
                  <p>{f.a}</p>
                </details>
              ))
            }
          </div>
        </section>

        <!-- Embed this calculator (copyable iframe + backlink) -->
        <EmbedCode slug={tool.slug} title={tool.title} />

        <!-- Sources -->
        <section class="prose" aria-labelledby="tool-sources">
          <h2 id="tool-sources">Sources &amp; references</h2>
          <ol class="tool__sources">
            {
              content.sources.map((src) => (
                <li>
                  {src.url ? <a href={src.url} target="_blank" rel="noopener nofollow">{src.citation}</a> : src.citation}
                </li>
              ))
            }
          </ol>
        </section>

        <!-- Disclaimer (sized to risk: high-risk tools get the prominent variant) -->
        <aside class:list={['tool__disclaimer', tool.riskLevel === 'high' && 'tool__disclaimer--high']} role="note">
          <Icon name="shield" size={20} />
          <p>
            <strong>Medical disclaimer:</strong> This calculator is for general
            information and education only and is not medical advice, diagnosis, or
            treatment. Results are estimates based on population formulas. Always
            consult a qualified healthcare professional about your health.
          </p>
        </aside>
      </div>

      <!-- Related tools + Wellness Hub guides -->
      <aside class="tool__related" aria-labelledby="related-title">
        <RelatedTools tool={tool} tools={related} articles={guides} />
        <AdSlot placement="sidebar" format="sidebar" />
      </aside>
    </div>

    <!-- Branded footer shown only when printing / saving to PDF -->
    <div class="print-only print-sheet-foot">
      <p>
        <strong>Not medical advice.</strong> This result is an educational estimate from {SITE.name}
        ({SITE.tagline}), based on population formulas — not a diagnosis or treatment. Always consult a
        qualified healthcare professional about your health.
      </p>
      <p class="print-sheet-foot__url">{pageUrl}</p>
    </div>
  </article>
</BaseLayout>

<style>
  .tool__header {
    padding-block: clamp(1.5rem, 4vw, 2.5rem);
  }
  .tool__header h1 {
    margin: 0.85rem 0 0.5rem;
  }
  .tool__header .lead {
    max-width: 60ch;
  }
  .tool__notice {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    margin-top: 1.25rem;
    max-width: 70ch;
    padding: 0.85rem 1.1rem;
    border-radius: var(--radius);
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #92400e;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.5;
  }
  .tool__notice svg {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .tool__icon-wrap {
    margin-top: 1.25rem;
  }
  .tool__byline {
    margin-top: 1.25rem;
  }
  .tool__cat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.85rem;
    font-weight: 700;
    font-size: 0.82rem;
    padding: 0.35rem 0.8rem;
    border-radius: var(--radius-pill);
    color: var(--c);
    background: color-mix(in srgb, var(--c) 12%, white);
    border: 1px solid color-mix(in srgb, var(--c) 28%, white);
  }

  .tool__calc {
    margin-top: clamp(-1.5rem, -3vw, -2.5rem);
    position: relative;
    z-index: 1;
    margin-bottom: 1.25rem;
  }
  .tool__answer {
    max-width: 72ch;
    margin: 0 0 clamp(1.25rem, 3vw, 2rem);
    padding: 1rem 1.25rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-left: 4px solid var(--green-primary);
    border-radius: var(--radius-sm);
  }
  .tool__answer-q {
    margin: 0 0 0.4rem;
    font-size: 1.02rem;
  }
  .tool__answer-a {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--ink);
  }

  .tool__result-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin: 0 0 clamp(2rem, 4vw, 3rem);
    max-width: 72ch;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--muted);
  }
  .tool__result-note svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--green-primary);
  }

  .tool__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    align-items: start;
  }

  .prose {
    margin-bottom: 2.25rem;
  }
  .prose h2 {
    font-size: 1.5rem;
    margin-bottom: 0.85rem;
  }
  .prose p {
    margin-bottom: 0.9rem;
    color: #334155;
  }
  .prose__list {
    display: grid;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }
  .prose__list li {
    display: flex;
    gap: 0.6rem;
    color: #334155;
  }
  .prose__check {
    color: var(--green-primary);
    flex-shrink: 0;
    margin-top: 3px;
  }

  /* FAQ */
  .tool__faq {
    display: grid;
    gap: 0.6rem;
  }
  .tool__faq details {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
  }
  .tool__faq summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.15rem;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 700;
    list-style: none;
  }
  .tool__faq summary::-webkit-details-marker {
    display: none;
  }
  .tool__faq-chev {
    color: var(--green-primary);
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }
  .tool__faq details[open] .tool__faq-chev {
    transform: rotate(180deg);
  }
  .tool__faq details p {
    margin: 0;
    padding: 0 1.15rem 1.15rem;
    color: var(--muted);
  }

  /* Sources */
  .tool__sources {
    list-style: decimal;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.6rem;
  }
  .tool__sources li {
    font-size: 0.9rem;
    color: var(--muted);
    list-style: decimal;
  }
  .tool__sources a {
    color: var(--green-700);
  }

  /* Affiliate recommendations */
  .affil {
    margin-bottom: 2.25rem;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.4rem;
  }
  .affil h2 {
    font-size: 1.3rem;
    margin: 0 0 0.35rem;
  }
  .affil__intro {
    margin: 0 0 0.5rem;
    color: var(--muted);
  }
  .affil__ftc {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0 0 1rem;
    font-size: 0.78rem;
    color: var(--muted);
    font-style: italic;
  }
  .affil__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
  }
  .affil__grid a {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    height: 100%;
    padding: 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--ink);
  }
  .affil__grid a:hover {
    text-decoration: none;
    border-color: var(--green-accent);
    box-shadow: var(--shadow-sm);
  }
  .affil__grid strong {
    font-family: var(--font-display);
    font-size: 1rem;
  }
  .affil__grid span {
    font-size: 0.85rem;
    color: var(--muted);
  }
  .affil__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: auto;
    padding-top: 0.4rem;
    color: var(--green-700) !important;
    font-weight: 700;
    font-size: 0.82rem !important;
  }
  @media (max-width: 640px) {
    .affil__grid {
      grid-template-columns: 1fr;
    }
  }

  /* Disclaimer */
  .tool__disclaimer {
    display: flex;
    gap: 0.75rem;
    align-items: flex-start;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
