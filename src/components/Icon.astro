---
/**
 * SVG icons (lucide-style, stroke = currentColor) rendered as <use> references
 * to the shared sprite at /icons/sprite.svg (generated from src/lib/icon-paths.ts
 * by scripts/gen-icon-sprite.ts — runs as prebuild). One cached 12 KB file
 * replaces ~300–700 bytes of inline markup per icon instance.
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  /** Decorative icons get aria-hidden; pass a label to expose to AT. */
  label?: string;
}

const { name, size = 24, class: className, label } = Astro.props;
const decorative = !label;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  class:list={['icn', className]}
  aria-hidden={decorative ? 'true' : undefined}
  role={decorative ? undefined : 'img'}
  aria-label={label}
>
  <use href={`/icons/sprite.svg#i-${name}`} />
</svg>
