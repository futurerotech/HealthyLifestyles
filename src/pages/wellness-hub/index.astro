---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Icon from '../../components/Icon.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import '../../styles/wellness-hub.css';
import { getSiteConsts } from '../../lib/cms';
import {
  getArticles,
  getArticleCategories,
  getFeaturedArticle,
  getLatestArticles,
  getArticleCategory,
  countArticlesByCategory,
} from '../../lib/cms';
import { articlePlainText } from '../../data/articles';
import { readingTimeMinutes, formatDate } from '../../lib/text';

const [siteConsts, articles, ARTICLE_CATEGORIES] = await Promise.all([
  getSiteConsts(), getArticles(), getArticleCategories(),
]);
const SITE = siteConsts.SITE;

const featured = await getFeaturedArticle();
const featuredCat = (await getArticleCategory(featured.category))!;
const featuredMinutes = readingTimeMinutes(articlePlainText(featured));
// Everything else, newest first (featured already gets the hero spot).
const latest = await getLatestArticles(articles.length, featured.slug);

const origin = Astro.site ?? new URL('https://www.healthylifesstyles.com');
const pageUrl = new URL('/wellness-hub', origin).href.replace(/\/$/, '');

const title = 'Wellness Hub — Evidence-Based Health Guides';
const description =
  'Plain-English, sourced health guides that explain the science and link to free calculators — nutrition, weight loss, sleep, fitness, and more.';

const items = [
  { label: 'Home', href: '/' },
  { label: 'Wellness Hub' },
];

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: new URL(c.href, origin).href.replace(/\/$/, '') } : {}),
  })),
};

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Wellness Hub',
  description,
  url: pageUrl,
  hasPart: articles.map((a) => ({


    '@type': 'Article',
    headline: a.title,
    url: new URL(`/wellness-hub/${a.slug}`, origin).href,
    datePublished: a.publishDate,
    dateModified: a.updatedDate,
  })),
};
---

<BaseLayout title={title} description={description} type="website" jsonLd={[breadcrumbLd, collectionLd]}>
  <!-- Hero + search -->
  <header class="wh-hero">
    <div class="container">
      <Breadcrumb items={items} />
      <p class="wh-hero__eyebrow eyebrow"><Icon name="book" size={16} /> Wellness Hub</p>
      <h1>Health guides that actually help</h1>
      <p class="lead">
        Clear, sourced answers to the questions people really search — paired with the free
        {SITE.name} calculators so you can put the advice to work in seconds.
      </p>
      <form class="wh-search" role="search" action="/wellness-hub" method="get">
        <label for="wh-search-input" class="sr-only">Search guides</label>
        <input
          id="wh-search-input"
          type="search"
          name="q"
          placeholder="Search guides (e.g. protein, sleep, BMI)…"
          autocomplete="off"
        />
        <button type="submit" class="btn btn-primary">Search</button>
      </form>
    </div>
  </header>

  <!-- Featured guide -->
  <section class="wh-section">
    <div class="container">
      <div class="wh-section__head"><h2>Featured guide</h2></div>
      <a
        href={`/wellness-hub/${featured.slug}`}
        class="wh-featured card"
        style={`--c:${featuredCat.color}`}
      >
        <span
          class="wh-featured__media"
          style={`background: linear-gradient(135deg, ${featuredCat.color}, color-mix(in srgb, ${featuredCat.color} 65%, #0a1628))`}
        >
          <Icon name={featuredCat.icon} />
        </span>
        <span class="wh-featured__body">
          <span class="wh-featured__tag" style={`color:${featuredCat.color}`}>
            <Icon name="star" size={14} /> {featuredCat.name}
          </span>
          <h3>{featured.title}</h3>
          <p>{featured.excerpt}</p>
          <span class="wh-featured__meta">
            <span>{featuredMinutes} min read</span>
            <span class="dot" aria-hidden="true"></span>
            <span>Updated {formatDate(featured.updatedDate)}</span>
          </span>
          <span class="btn btn-primary" style="align-self:flex-start;margin-top:0.4rem;">
            Read the guide <Icon name="arrow-right" size={16} />
          </span>
        </span>
      </a>
    </div>
  </section>

  <!-- Category tiles -->
  <section class="wh-section section-surface-2">
    <div class="container">
      <div class="wh-section__head">
        <h2>Browse by topic</h2>
        <a href="/tools">All calculators <span aria-hidden="true">→</span></a>
      </div>
      <div class="wh-cats">
        {ARTICLE_CATEGORIES.map((c) => {
          const n = countArticlesByCategory(c.id);
          const inner = (
            <>
              <span class="wh-cat-tile__icon" style={`background:${c.color}1a;color:${c.color}`}>
                <Icon name={c.icon} size={22} />
              </span>
              <span>
                <span class="wh-cat-tile__name">{c.name}</span><br />
                <span class="wh-cat-tile__count">{n === 0 ? 'Coming soon' : `${n} ${n === 1 ? 'guide' : 'guides'}`}</span>
              </span>
            </>
          );
          // 0-guide categories render as a muted, non-clickable tile (no <a>).
          return n === 0 ? (
            <div class="wh-cat-tile wh-cat-tile--soon card" aria-disabled="true">{inner}</div>
          ) : (
            <a href={`/wellness-hub/${c.slug}`} class="wh-cat-tile card">{inner}</a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Latest (searchable) -->
  <section class="wh-section">
    <div class="container">
      <div class="wh-section__head"><h2>Latest guides</h2></div>
      <ul class="wh-grid" id="wh-results">
        {latest.map((a) => (
          <li><ArticleCard article={a} /></li>
        ))}
      </ul>
      <p class="wh-empty" id="wh-noresults" hidden>
        No guides match your search yet. Try a broader term, or
        <a href="/tools"> browse the calculators</a>.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="wh-section section-mint">
    <div class="container" style="text-align:center;max-width:640px;">
      <h2>Put the advice into action</h2>
      <p class="lead" style="margin:0.5rem auto 1.5rem;">
        Every guide pairs with a free, instant calculator. Get your full picture in one place.
      </p>
      <a href="/health-score" class="btn btn-primary btn-lg">
        Get My Health Score <Icon name="arrow-right" size={18} />
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  // Client-side filter for the "Latest guides" grid. Reads ?q= on load and
  // filters as you type. Pure DOM, no dependencies.
  const input = document.getElementById('wh-search-input') as HTMLInputElement | null;
  const results = document.getElementById('wh-results');
  const noResults = document.getElementById('wh-noresults');
  if (input && results) {
    const cards = Array.from(results.querySelectorAll('li'));
    const apply = (q: string) => {
      const query = q.trim().toLowerCase();
      let shown = 0;
      cards.forEach((li) => {
        const card = li.querySelector('[data-search]') as HTMLElement | null;
        const hay = card?.dataset.search ?? '';
        const match = !query || hay.includes(query);
        li.hidden = !match;
        if (match) shown++;
      });
      if (noResults) noResults.hidden = shown !== 0;
    };
    const params = new URLSearchParams(window.location.search);
    const initial = params.get('q') ?? '';
    if (initial) input.value = initial;
    apply(initial);
    input.addEventListener('input', () => apply(input.value));
    // Keep it client-side: don't reload on submit.
    input.form?.addEventListener('submit', (e) => { e.preventDefault(); apply(input.value); });
  }
</script>
