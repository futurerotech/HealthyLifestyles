---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleBody from '../../components/ArticleBody.astro';
import ArticleArchiveBody from '../../components/ArticleArchiveBody.astro';
import '../../styles/wellness-hub.css';
import { getSiteConsts } from '../../lib/cms';
import {
  getArticles,
  getArticleCategories,
  getArticle,
  getArticleCategory,
  getArticlesByCategory,
  ARTICLES_PER_PAGE,
  resolveAuthor,
  REVIEWER_SLUG,
} from '../../lib/cms';
import { articleFaq } from '../../data/articles';
import type { Article, ArticleBlock } from '../../data/articles';

export async function getStaticPaths() {
  const [articles, ARTICLE_CATEGORIES] = await Promise.all([getArticles(), getArticleCategories()]);
  const paths: any[] = [];

  // Article pages: /wellness-hub/[slug]
  for (const a of articles) {
    paths.push({ params: { path: a.slug }, props: { kind: 'article', slug: a.slug } });
  }

  // Category archives: /wellness-hub/[category] (+ /[category]/[n] for page 2+)
  for (const c of ARTICLE_CATEGORIES) {
    const all = await getArticlesByCategory(c.id);
    const count = all.length;
    const totalPages = Math.max(1, Math.ceil(count / ARTICLES_PER_PAGE));
    for (let p = 1; p <= totalPages; p++) {
      paths.push({
        params: { path: p === 1 ? c.slug : `${c.slug}/${p}` },
        props: { kind: 'archive', categoryId: c.id, page: p },
      });
    }
  }

  return paths;
}

const props = Astro.props as
  | { kind: 'article'; slug: string }
  | { kind: 'archive'; categoryId: string; page: number };

const origin = Astro.site ?? new URL('https://www.healthylifesstyles.com');
const pageUrl = new URL(Astro.url.pathname, origin).href.replace(/\/$/, '');

let title = '';
let description = '';
let image: string | undefined;
let jsonLd: Record<string, unknown>[] = [];

const breadcrumb = (crumbs: { label: string; href?: string }[]) => ({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: c.label,
    ...(c.href ? { item: { '@id': new URL(c.href, origin).href.replace(/\/$/, ''), name: c.label } } : {}),
  })),
});

// --- Advanced schema builders (emitted when the CMS flag is set — Phase 9;
//     the title/step heuristics were removed in favour of the isHowTo /
//     isHealthTopic booleans, which are the single source of truth). ---
function buildHowTo(a: Article, pageUrl: string, ogImage: string): Record<string, unknown> | null {
  const steps: { name: string; text: string }[] = [];
  let current: { name: string; texts: string[] } | null = null;

  for (const block of a.body) {
    if (block.type === 'h2' || block.type === 'h3') {
      if (current) steps.push({ name: current.name, text: current.texts.join(' ') });
      current = { name: block.text, texts: [] };
    } else if (current) {
      if (block.type === 'p') current.texts.push(block.text);
      else if (block.type === 'ul') current.texts.push(...block.items);
      else if (block.type === 'ol') current.texts.push(...block.items);
    }
  }
  if (current) steps.push({ name: current.name, text: current.texts.join(' ') });

  if (steps.length === 0) return null;

  return {
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    '@id': `${pageUrl}#howto`,
    name: a.title,
    description: a.metaDescription,
    image: ogImage,
    totalTime: undefined,
    step: steps.map((s, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: s.name,
      text: s.text,
    })),
  };
}

function buildHealthTopicContent(
  a: Article,
  pageUrl: string,
  author: ReturnType<typeof authorLd>,
  reviewer: ReturnType<typeof authorLd>,
): Record<string, unknown> | null {
  const topic = a.semanticEntities?.[0]?.term || a.title.replace(/^what is (an? )?/i, '').replace(/\?$/, '');
  if (!topic) return null;

  return {
    '@context': 'https://schema.org',
    '@type': 'HealthTopicContent',
    '@id': `${pageUrl}#topic`,
    about: { '@type': 'MedicalCondition', name: topic },
    mainEntity: { '@type': 'MedicalCondition', name: topic },
    text: a.excerpt,
    url: pageUrl,
    author,
    reviewedBy: reviewer,
    lastReviewed: a.updatedDate,
  };
}

// --- Article branch ---
let article = props.kind === 'article' ? await getArticle(props.slug) : null;

// --- Archive branch ---
let archive: {
  category: NonNullable<Awaited<ReturnType<typeof getArticleCategory>>>;
  pageArticles: NonNullable<Awaited<ReturnType<typeof getArticle>>>[];
  total: number;
  page: number;
  totalPages: number;
} | null = null;

if (props.kind === 'article' && article) {
  const [category, siteConsts] = await Promise.all([
    getArticleCategory(article.category),
    getSiteConsts(),
  ]);
  const SITE = siteConsts.SITE;
  title = article.seoTitle;
  description = article.metaDescription;
  // Per-article branded OG card (build-time PNG); falls back to the site default.
  const ogImage = new URL(`/og/articles/${article.slug}.png`, origin).href;
  image = ogImage;

  const categorySafe = category!;

  const entities = article.semanticEntities || [];
  const authorEntity = await resolveAuthor(article.author);
  // Health articles must be reviewed by the medical review board. If the CMS
  // reviewer relation is missing or incorrectly points back to the author,
  // fall back to the canonical medical reviewer.
  const rawReviewer = article.reviewer || REVIEWER_SLUG;
  const reviewerEntity =
    rawReviewer === article.author || rawReviewer === 'editorial-team'
      ? await resolveAuthor(REVIEWER_SLUG)
      : await resolveAuthor(rawReviewer);
  const orgId = `${origin.href}#org`;

  function authorLd(a: typeof authorEntity) {
    return {
      '@type': a.schemaType,
      '@id': new URL(`/author/${a.slug}`, origin).href,
      name: a.name,
      url: new URL(`/author/${a.slug}`, origin).href,
      ...(a.credential ? { credential: a.credential } : {}),
      ...(a.schemaType === 'Person'
        ? { jobTitle: a.role, worksFor: { '@id': orgId } }
        : {}),
    };
  }

  const articleLd = {
    '@context': 'https://schema.org',
    '@type': ['MedicalWebPage', 'Article'],
    '@id': pageUrl,
    headline: article.title,
    description: article.metaDescription,
    datePublished: article.publishDate,
    dateModified: article.updatedDate,
    lastReviewed: article.updatedDate,
    author: authorLd(authorEntity),
    reviewedBy: authorLd(reviewerEntity),
    publisher: { '@id': orgId },
    mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
    image: ogImage,
    articleSection: categorySafe.name,
    inLanguage: 'en',
    audience: {
      '@type': 'MedicalAudience',
      audienceType: 'Patient',
      healthCondition: entities.length
        ? entities.map((e) => ({ '@type': 'MedicalCondition', name: e.term }))
        : undefined,
    },
    ...(entities.length
      ? {
          about: entities.map((e) => ({ '@type': 'DefinedTerm', name: e.term, ...(e.url ? { url: e.url } : {}) })),
          keywords: entities.map((e) => e.term).join(', '),
        }
      : {}),
  };

  jsonLd = [
    breadcrumb([
      { label: 'Home', href: '/' },
      { label: 'Wellness Hub', href: '/wellness-hub' },
      { label: categorySafe.name, href: `/wellness-hub/${categorySafe.slug}` },
      { label: article.title },
    ]),
    articleLd,
  ];

  if (article.isHowTo) {
    const howTo = buildHowTo(article, pageUrl, ogImage);
    if (howTo) jsonLd.push(howTo);
  }

  if (article.isHealthTopic) {
    const topic = buildHealthTopicContent(article, pageUrl, authorLd(authorEntity), authorLd(reviewerEntity));
    if (topic) jsonLd.push(topic);
  }

  const faq = articleFaq(article);
  if (faq.length) {
    jsonLd.push({
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    });
  }
} else if (props.kind === 'archive') {
  const [category, siteConsts, all] = await Promise.all([
    getArticleCategory(props.categoryId),
    getSiteConsts(),
    getArticlesByCategory(props.categoryId),
  ]);
  const SITE = siteConsts.SITE;
  const categorySafe = category!;
  const totalPages = Math.max(1, Math.ceil(all.length / ARTICLES_PER_PAGE));
  const page = props.page;
  const pageArticles = all.slice((page - 1) * ARTICLES_PER_PAGE, page * ARTICLES_PER_PAGE);
  archive = { category: categorySafe, pageArticles: pageArticles as typeof archive.pageArticles, total: all.length, page, totalPages };

  title =
    page > 1
      ? `${categorySafe.name} Guides — Page ${page} | Wellness Hub`
      : `${categorySafe.name} Guides | Wellness Hub`;
  description = `${categorySafe.blurb} Evidence-based ${categorySafe.name.toLowerCase()} guides from the ${SITE.name} Wellness Hub.`;

  jsonLd = [
    breadcrumb([
      { label: 'Home', href: '/' },
      { label: 'Wellness Hub', href: '/wellness-hub' },
      { label: categorySafe.name },
    ]),
    {
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: `${categorySafe.name} Guides`,
      description,
      url: pageUrl,
      hasPart: all.map((a) => ({
        '@type': 'Article',
        headline: a.title,
        url: new URL(`/wellness-hub/${a.slug}`, origin).href,
        datePublished: a.publishDate,
        dateModified: a.updatedDate,
      })),
    },
  ];
}
---

<BaseLayout title={title} description={description} image={image} type={article ? 'article' : 'website'} jsonLd={jsonLd}>
  <Fragment slot="head">
    {article?.heroImage?.url && (
      <link
        rel="preload"
        as="image"
        href={article.heroImage.url}
        fetchpriority="high"
      />
    )}
  </Fragment>
  {article && <ArticleBody article={article} pageUrl={pageUrl} />}
  {archive && (
    <ArticleArchiveBody
      category={archive.category}
      articles={archive.pageArticles}
      total={archive.total}
      page={archive.page}
      totalPages={archive.totalPages}
    />
  )}
</BaseLayout>
