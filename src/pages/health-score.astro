---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Icon from '../components/Icon.astro';
import HealthScore from '../islands/HealthScore.tsx';
import { SITE } from '../consts';
import '../styles/health-score.css';

const items = [{ label: 'Home', href: '/' }, { label: 'Health Score' }];

// The six sub-scores the assessment produces, each linking to its category hub.
const measures = [
  { icon: 'scale', color: 'var(--c-body)', title: 'Body Composition', body: 'BMI and waist-to-height to gauge a healthy weight and central fat.', href: '/body-weight' },
  { icon: 'dumbbell', color: 'var(--c-fitness)', title: 'Activity', body: 'How much you move in a typical week, refined by resting heart rate.', href: '/fitness' },
  { icon: 'leaf', color: 'var(--c-nutrition)', title: 'Nutrition', body: 'Fruit & veg servings and daily hydration habits.', href: '/nutrition' },
  { icon: 'moon', color: 'var(--c-sleep)', title: 'Sleep', body: 'Whether you get enough consistent, restful sleep.', href: '/sleep' },
  { icon: 'gauge', color: 'var(--c-risk)', title: 'Lifestyle', body: 'Smoking and alcohol — two of the biggest modifiable factors.', href: '/health-risk' },
  { icon: 'smile', color: 'var(--c-mind)', title: 'Stress', body: 'How often stress is weighing on you day to day.', href: '/mental-wellness' },
];

const title = `Free Health Score Assessment | ${SITE.name}`;
const description =
  'Take the free Health Score assessment in under 3 minutes. Get six wellness sub-scores, an overall score, and a personalized plan — no signup.';

const origin = Astro.site ?? new URL('https://www.healthylifestyles.com');
const appLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'HealthyLifeStyles Health Score',
  url: new URL('/health-score', origin).href,
  applicationCategory: 'HealthApplication',
  operatingSystem: 'Any (web browser)',
  description,
  isAccessibleForFree: true,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: SITE.name },
};
---

<BaseLayout title={title} description={description} jsonLd={[appLd]}>
  <section class="hsx-hero">
    <div class="container">
      <Breadcrumb items={items} />
      <div class="hsx-hero__copy">
        <span class="hsx-hero__badge"><Icon name="shield" size={16} /> Private · No signup · Under 3 minutes</span>
        <h1>Your free <span class="text-accent">Health Score</span></h1>
        <p>
          A private snapshot of your overall wellness across six areas, with a personalized plan
          and links to the exact tools that help. Everything stays on your device.
        </p>
      </div>
    </div>
  </section>

  <section class="hsx-assess" data-tool="health-score">
    <div class="container">
      <HealthScore client:load />
    </div>
  </section>

  <section class="section section-surface-2">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">What your score measures</span>
        <h2>Six areas of everyday wellness</h2>
        <p class="lead">Your overall Health Score is a weighted blend of these six sub-scores.</p>
      </div>
      <ul class="hsx-measures">
        {
          measures.map((p) => (
            <li>
              <a href={p.href} class="card hsx-measure">
                <span class="icon-tile" style={`background:${p.color}1a;color:${p.color}`}>
                  <Icon name={p.icon} />
                </span>
                <h3>{p.title}</h3>
                <p>{p.body}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="container container-narrow">
      <div class="hsx-note">
        <Icon name="shield" size={22} />
        <p>
          <strong>Educational, not diagnostic.</strong> Your Health Score is a general wellness
          indicator built from validated formulas. It is not a medical assessment and cannot
          diagnose any condition. Always consult a qualified healthcare provider about your health.
          See our <a href="/medical-disclaimer">medical disclaimer</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hsx-hero {
    background:
      radial-gradient(700px 360px at 85% -10%, rgba(34, 197, 94, 0.25), transparent 60%),
      var(--dark);
    color: #fff;
    padding-block: clamp(1.5rem, 4vw, 2rem) clamp(4rem, 9vw, 6.5rem);
  }
  .hsx-hero :global(.crumbs a) { color: #94a3b8; }
  .hsx-hero :global(.crumbs [aria-current='page']) { color: #e2e8f0; }
  .hsx-hero :global(.crumbs__sep) { color: #475569; }
  .hsx-hero__copy {
    max-width: 640px;
    margin-top: 1.25rem;
  }
  .hsx-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.4rem 0.9rem;
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.85rem;
    font-weight: 600;
  }
  .hsx-hero h1 {
    color: #fff;
    margin: 1rem 0 0.75rem;
    font-size: clamp(2.2rem, 5vw, 3.2rem);
  }
  .hsx-hero__copy p {
    color: #cbd5e1;
    font-size: 1.1rem;
    margin: 0;
  }

  /* Assessment card overlaps the hero, matching the tool-page aesthetic */
  .hsx-assess {
    margin-top: clamp(-3.5rem, -7vw, -5rem);
    position: relative;
    z-index: 1;
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }

  .hsx-measures {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }
  .hsx-measure {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    padding: 1.5rem;
    height: 100%;
    color: inherit;
  }
  .hsx-measure:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .hsx-measure h3 {
    margin: 0.6rem 0 0.2rem;
    font-size: 1.1rem;
  }
  .hsx-measure p {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .hsx-note {
    display: flex;
    gap: 0.9rem;
    background: var(--mint-50);
    border: 1px solid #d1fae5;
    border-radius: var(--radius);
    padding: 1.25rem 1.4rem;
    color: var(--green-700);
  }
  .hsx-note p {
    margin: 0;
    color: #334155;
    font-size: 0.95rem;
  }

  @media (max-width: 820px) {
    .hsx-measures {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .hsx-measures {
      grid-template-columns: 1fr;
    }
  }
</style>
