---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Icon from '../components/Icon.astro';
import { SITE, CONTACT } from '../consts';

const items = [{ label: 'Home', href: '/' }, { label: 'Contact' }];

const CONTACT_EMAIL = CONTACT.email;
const ENDPOINT = CONTACT.endpoint;
const hasEndpoint = /^https?:\/\//.test(ENDPOINT);

const reasons = [
  {
    icon: 'flask',
    color: 'var(--c-body)',
    title: 'Tool requests & feedback',
    body: 'Suggest a calculator, report a result that looks off, or tell us how a tool could be clearer.',
  },
  {
    icon: 'book',
    color: 'var(--c-nutrition)',
    title: 'Content & corrections',
    body: 'Spotted an error in a formula, source, or explanation? Let us know and we’ll review it quickly.',
  },
  {
    icon: 'lock',
    color: 'var(--green-primary)',
    title: 'Privacy & legal',
    body: 'Questions about our privacy practices, terms, or how the site handles data.',
  },
];

const title = `Contact Us | ${SITE.name}`;
const description = `Get in touch with the ${SITE.name} team. Request a tool, report an issue, or ask about privacy — we read every message.`;
---

<BaseLayout title={title} description={description}>
  <header class="contact__header section-mint">
    <div class="container">
      <Breadcrumb items={items} />
      <div class="contact__head">
        <span class="eyebrow">Contact</span>
        <h1>We'd love to hear from you</h1>
        <p class="lead">
          Have a question, a tool idea, or a correction? Send us a message and we'll
          get back to you. We typically reply within two business days.
        </p>
      </div>
    </div>
  </header>

  <section class="section">
    <div class="container contact__grid">
      <div class="contact__form-wrap card">
        <h2>Send a message</h2>
        <p class="contact__form-note">
          Fields marked with <span aria-hidden="true">*</span> are required.
        </p>
        <form id="contact-form" class="contact__form" novalidate>
          <div class="contact__field">
            <label for="cf-name">Name <span class="req" aria-hidden="true">*</span></label>
            <input type="text" id="cf-name" name="name" required autocomplete="name" />
          </div>
          <div class="contact__field">
            <label for="cf-email">Email <span class="req" aria-hidden="true">*</span></label>
            <input type="email" id="cf-email" name="email" required autocomplete="email" />
          </div>
          <div class="contact__field">
            <label for="cf-subject">Subject</label>
            <select id="cf-subject" name="subject">
              <option>Tool request or feedback</option>
              <option>Report a problem</option>
              <option>Content correction</option>
              <option>Privacy or legal</option>
              <option>Something else</option>
            </select>
          </div>
          <div class="contact__field">
            <label for="cf-message">Message <span class="req" aria-hidden="true">*</span></label>
            <textarea id="cf-message" name="message" rows="6" required></textarea>
          </div>
          <p id="cf-error" class="contact__error" role="alert" hidden></p>
          <p id="cf-success" class="contact__success" role="status" hidden>
            <Icon name="check" size={16} /> Thanks — your message has been sent. We’ll reply soon.
          </p>
          <button type="submit" class="btn btn-primary btn-lg">
            <span class="cf-btn-label">{hasEndpoint ? 'Send message' : 'Open email to send'}</span>
            <Icon name="arrow-right" size={18} />
          </button>
          <p class="contact__privacy">
            <Icon name="lock" size={14} />
            {hasEndpoint
              ? 'Your message is sent securely to our team — we only use it to reply to you.'
              : 'Your message opens in your own email app — nothing is submitted to or stored by this website.'}
          </p>
        </form>
      </div>

      <aside class="contact__aside">
        <div class="card contact__direct">
          <h2>Email us directly</h2>
          <p>Prefer your own inbox? Reach us any time at:</p>
          <a href={`mailto:${CONTACT_EMAIL}`} class="contact__email">
            <Icon name="arrow-right" size={16} /> {CONTACT_EMAIL}
          </a>
        </div>

        <ul class="contact__reasons">
          {reasons.map((r) => (
            <li class="card contact__reason">
              <span class="icon-tile" style={`background:${r.color}1a;color:${r.color}`}>
                <Icon name={r.icon} />
              </span>
              <div>
                <h3>{r.title}</h3>
                <p>{r.body}</p>
              </div>
            </li>
          ))}
        </ul>

        <div class="card contact__note">
          <p>
            <strong>Not medical advice.</strong> We can't provide personal medical
            guidance. For health concerns, please consult a qualified healthcare
            provider. See our <a href="/medical-disclaimer">medical disclaimer</a>.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact__header {
    padding-block: clamp(1.75rem, 4vw, 2.75rem);
  }
  .contact__head {
    max-width: 60ch;
    margin-top: 1rem;
  }
  .contact__head h1 {
    margin: 0.4rem 0 0.6rem;
  }
  .contact__head .lead {
    margin: 0;
  }

  .contact__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: start;
  }

  .contact__form-wrap {
    padding: clamp(1.5rem, 4vw, 2.25rem);
  }
  .contact__form-wrap h2 {
    margin: 0 0 0.3rem;
  }
  .contact__form-note {
    color: var(--muted);
    font-size: 0.9rem;
    margin: 0 0 1.25rem;
  }
  .contact__form {
    display: grid;
    gap: 1.1rem;
  }
  .contact__field {
    display: grid;
    gap: 0.4rem;
  }
  .contact__field label {
    font-weight: 600;
    font-size: 0.92rem;
  }
  .req {
    color: var(--c-heart);
  }
  .contact__field input,
  .contact__field select,
  .contact__field textarea {
    font: inherit;
    color: var(--ink);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 0.7rem 0.85rem;
    width: 100%;
  }
  .contact__field textarea {
    resize: vertical;
  }
  .contact__field input:focus,
  .contact__field select:focus,
  .contact__field textarea:focus {
    outline: none;
    border-color: var(--green-accent);
    box-shadow: var(--focus-ring);
  }
  .contact__error {
    color: var(--c-heart);
    font-size: 0.9rem;
    font-weight: 600;
    margin: 0;
  }
  .contact__error[hidden] {
    display: none;
  }
  .contact__success {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--green-700);
  }
  .contact__success[hidden] {
    display: none;
  }
  .contact__success svg {
    color: var(--green-primary);
  }
  .contact__privacy {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--muted);
    margin: 0;
  }

  .contact__aside {
    display: grid;
    gap: 1.25rem;
  }
  .contact__direct {
    padding: 1.6rem;
  }
  .contact__direct h2 {
    font-size: 1.2rem;
    margin: 0 0 0.4rem;
  }
  .contact__direct p {
    color: var(--muted);
    font-size: 0.92rem;
    margin: 0 0 0.8rem;
  }
  .contact__email {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--green-700);
    word-break: break-all;
  }

  .contact__reasons {
    display: grid;
    gap: 1rem;
  }
  .contact__reason {
    display: flex;
    gap: 1rem;
    padding: 1.25rem;
  }
  .contact__reason h3 {
    font-size: 1.05rem;
    margin: 0 0 0.3rem;
  }
  .contact__reason p {
    margin: 0;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .contact__note {
    padding: 1.25rem 1.4rem;
    background: var(--mint-50);
    border-color: #d1fae5;
  }
  .contact__note p {
    margin: 0;
    font-size: 0.9rem;
    color: #334155;
  }

  @media (max-width: 860px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline define:vars={{ CONTACT_EMAIL, ENDPOINT }}>
  // Posts to the configured form endpoint when one is set; otherwise hands off
  // to the visitor's email client. Either way, no message is lost.
  const form = document.getElementById('contact-form');
  const errorEl = document.getElementById('cf-error');
  const successEl = document.getElementById('cf-success');
  const hasEndpoint = /^https?:\/\//.test(ENDPOINT || '');

  function mailtoFallback(name, email, subject, message) {
    const body = `Name: ${name}\nEmail: ${email}\n\n${message}`;
    window.location.href =
      `mailto:${CONTACT_EMAIL}` +
      `?subject=${encodeURIComponent('[' + subject + '] ' + name)}` +
      `&body=${encodeURIComponent(body)}`;
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = form.elements['name'].value.trim();
      const email = form.elements['email'].value.trim();
      const subject = form.elements['subject'].value;
      const message = form.elements['message'].value.trim();

      const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
      if (!name || !emailOk || !message) {
        errorEl.textContent = 'Please add your name, a valid email, and a message.';
        errorEl.hidden = false;
        return;
      }
      errorEl.hidden = true;

      // No endpoint configured yet → open the user's email app.
      if (!hasEndpoint) {
        mailtoFallback(name, email, subject, message);
        return;
      }

      const btn = form.querySelector('button[type="submit"]');
      const label = btn && btn.querySelector('.cf-btn-label');
      const prev = label ? label.textContent : '';
      if (btn) btn.disabled = true;
      if (label) label.textContent = 'Sending…';

      try {
        const res = await fetch(ENDPOINT, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        if (!res.ok) throw new Error('Request failed');
        form.reset();
        if (successEl) {
          successEl.hidden = false;
          successEl.scrollIntoView({ block: 'nearest' });
        }
      } catch (err) {
        // Provider/network problem — fall back to email so nothing is lost.
        errorEl.textContent = 'We couldn’t send that through the form — opening your email app instead.';
        errorEl.hidden = false;
        mailtoFallback(name, email, subject, message);
      } finally {
        if (btn) btn.disabled = false;
        if (label) label.textContent = prev;
      }
    });
  }
</script>
