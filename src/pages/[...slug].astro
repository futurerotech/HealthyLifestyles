---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageRenderer from '../components/blocks/PageRenderer.astro';
import { getCmsPage, getCmsPages } from '../lib/cms';

export async function getStaticPaths() {
  const pages = await getCmsPages();
  return pages
    .filter((p) => p.slug && p.slug !== 'index' && p.slug !== 'home')
    .map((p) => ({
      params: { slug: p.slug },
      props: { slug: p.slug },
    }));
}

const { slug } = Astro.props;
const page = await getCmsPage(slug!);

if (!page) {
  return Astro.redirect('/404', 404);
}

const title = page.title ?? '';
const blocks = (page.layout as any[]) ?? [];
const heroImage = page.heroImage as { url?: string; alt?: string; width?: number; height?: number } | undefined;

const origin = Astro.site ?? new URL('https://www.healthylifesstyles.com');
const pageUrl = new URL(Astro.url.pathname, origin).href.replace(/\/$/, '');
const pageLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': pageUrl,
  name: title,
  url: pageUrl,
  description: title,
  inLanguage: 'en',
};
---

<BaseLayout title={title} description={title} jsonLd={[pageLd]}>
  <Fragment slot="head">
    {heroImage?.url && (
      <link rel="preload" as="image" href={heroImage.url} fetchpriority="high" />
    )}
  </Fragment>
  <article class="cms-page">
    {heroImage?.url && (
      <img
        src={heroImage.url}
        alt={heroImage.alt ?? ''}
        width={heroImage.width || undefined}
        height={heroImage.height || undefined}
        class="cms-page__hero"
        loading="eager"
        fetchpriority="high"
      />
    )}
    <PageRenderer layout={blocks} />
  </article>
</BaseLayout>

<style>
  .cms-page { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem; }
  .cms-page__hero { display: block; width: 100%; height: auto; border-radius: 12px; margin-bottom: 2rem; }
</style>
